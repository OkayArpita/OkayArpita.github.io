---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/nav.astro';

const title = "Dr. A. P. J. Abdul Kalam Technical University";
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/#career" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="flex flex-row gap-6 md:gap-12 mb-2 reveal-content" style="animation-delay: 100ms;">
      <!-- AKTU Bubble -->
      <a href="https://aktu.ac.in/" target="_blank" rel="noopener noreferrer" class="achievement-tile block relative group cursor-pointer">
        <div class="balloon-float w-32 h-32 md:w-48 md:h-48 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center hover:scale-105 transition-transform duration-300">
          <img src="/AKTU.png" alt="AKTU" class="w-full h-full object-cover bg-white" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
        </div>
        <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[60px] opacity-30 group-hover:opacity-50 transition-opacity duration-500"></div>
      </a>
      

    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-3xl md:text-5xl font-heading font-bold text-maintext tracking-tight mt-6 leading-tight">
        {title}
      </h1>
      <p class="text-accent font-semibold mt-2 text-lg">Bachelor of Technology (B.Tech.)</p>
      <p class="text-gray text-sm mt-1">Oct 2023 - Jul 2027 | Electronics & Communication Engineering</p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-3">
        <span class="bg-accent/10 border border-accent/20 text-accent px-4 py-1.5 rounded-full text-sm font-semibold">KIET Group of Institutions</span>
        <span class="bg-accent/10 border border-accent/20 text-accent px-4 py-1.5 rounded-full text-sm font-semibold">CGPA: 7.71 / 10</span>
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">
    
    <!-- 2. Relevant Coursework -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Relevant Coursework
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 text-gray font-body text-base md:text-lg">
          <li class="flex items-center gap-3">Embedded System Design</li>
          <li class="flex items-center gap-3">FPGA & Digital System Architecture</li>
          <li class="flex items-center gap-3">Control Systems</li>
          <li class="flex items-center gap-3">Microprocessors & Microcontrollers</li>
          <li class="flex items-center gap-3">Sensors & Instrumentation</li>
          <li class="flex items-center gap-3">Real-Time Systems</li>
          <li class="flex items-center gap-3">Communication Systems</li>
          <li class="flex items-center gap-3">Analog & Digital Electronics</li>
          <li class="flex items-center gap-3">Data Structures & Algorithms</li>
        </ul>
      </div>
    </div>

    <!-- 3. Academic Highlights -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Academic Highlights
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-6">
        <ul class="space-y-4 text-gray font-body text-base md:text-lg list-none">
          <li class="flex items-start gap-4">
            <span class="text-accent text-2xl mt-0.5">✨</span>
            <span><strong>Research internships</strong> at prestigious institutions including IIT Bombay, IIT Madras, and EPFL.</span>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-accent text-2xl mt-0.5">🔬</span>
            <span>Applied academic knowledge to real-world impact in <strong>medical devices, robotics, and embedded systems</strong>.</span>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-accent text-2xl mt-0.5">🏆</span>
            <span>Participated and achieved top ranks in <strong>national and international robotics competitions</strong>.</span>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-accent text-2xl mt-0.5">🛠️</span>
            <span>Gained extensive hands-on experience in <strong>PCB design, embedded firmware, CAD, and rapid prototyping</strong>.</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- 4. Areas of Interest -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Areas of Interest
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <div class="flex flex-wrap gap-3">
          {["Robotics", "Embedded Systems", "Biomedical Engineering", "Medical Devices", "Control Systems", "FPGA & Digital Design", "Internet of Things (IoT)", "Assistive Technologies"].map(interest => (
            <span class="px-5 py-2 rounded-xl border border-accent/20 bg-background/50 hover:bg-accent/10 transition-colors text-maintext text-sm font-semibold shadow-sm cursor-default">
              {interest}
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- 5. MOOCs & Certifications -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> MOOCs & Certifications
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/AKTU/Basics of Embedded Systems and Robotics (Merit)_page-0001.jpg" alt="Embedded Systems MOOC" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Embedded Systems</p>
              <p class="text-gray text-xs mt-1">e-Yantra, IIT Bombay</p>
            </div>
          </div>
          
          <div class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/AKTU/ROS2 MOOC (Merit)_page-0001.jpg" alt="ROS 2 for Robotics MOOC" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">ROS 2 for Robotics</p>
              <p class="text-gray text-xs mt-1">e-Yantra, IIT Bombay</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 6. Academic Records -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Academic Records
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
          <div class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-[1/1.4] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/AKTU/Result_page-0001.jpg" alt="Semester Result Page 1" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Academic Transcript</p>
              <p class="text-gray text-xs mt-1">Page 1</p>
            </div>
          </div>
          
          <div class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-[1/1.4] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/AKTU/Result_page-0002.jpg" alt="Semester Result Page 2" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Academic Transcript</p>
              <p class="text-gray text-xs mt-1">Page 2</p>
            </div>
          </div>
          
          <div class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-[1/1.4] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/AKTU/Result_page-0003.jpg" alt="Semester Result Page 3" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Academic Transcript</p>
              <p class="text-gray text-xs mt-1">Page 3</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 7. Know my institution -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Know my institution
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <a href="https://aktu.ac.in/" target="_blank" rel="noopener noreferrer" class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md block">
            <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/AKTU/aboutaktu.jpg" alt="About AKTU" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">AKTU</p>
              <p class="text-gray text-xs mt-1">Dr. A.P.J. Abdul Kalam Technical University</p>
            </div>
          </a>
          
          <a href="https://www.kiet.edu/" target="_blank" rel="noopener noreferrer" class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md block">
            <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/AKTU/aboutkiet.jpg" alt="About KIET" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">KIET</p>
              <p class="text-gray text-xs mt-1">KIET Group of Institutions</p>
            </div>
          </a>
        </div>
      </div>
    </div>

    <!-- 8. Media & Featured -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Media & Featured
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-6">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed text-center">
          I was featured in a dedicated video discussing my journey through three years of my undergraduate studies, highlighting the achievements and competitions we participated in as a two-member team.
        </p>
        <div class="flex justify-center mt-4">
          <a href="https://www.linkedin.com/posts/%F0%9D%97%AA%F0%9D%97%AE%F0%9D%98%81%F0%9D%97%B0%F0%9D%97%B5-%F0%9D%97%B5%F0%9D%97%BC%F0%9D%98%84-%F0%9D%97%94%F0%9D%97%BF%F0%9D%97%BD%F0%9D%97%B6%F0%9D%98%81%F0%9D%97%AE-%F0%9D%97%94%F0%9D%97%BB%F0%9D%98%82%F0%9D%97%BD-ugcPost-7460977383735476225-CM5K/?highlightedUpdateUrn=urn%3Ali%3Aactivity%3A7465413816844050432&highlightedUpdateType=SOCIAL_SHARE&origin=SOCIAL_SHARE&utm_source=social_share_send&utm_medium=member_desktop_web&rcm=ACoAAEYVexMBjaryTgP9mTSI1ewZJ0EclC9co7A" target="_blank" rel="noopener noreferrer" class="achievement-tile block relative group rounded-xl overflow-hidden shadow-lg border border-accent/20 max-w-lg aspect-video w-full mx-auto">
            <img src="/Career/AKTU/featured.png" alt="KIET Featured Video" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-background/90 via-background/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-6">
              <span class="text-maintext font-heading font-semibold text-lg flex items-center gap-2 px-6 py-3 rounded-full bg-accent/20 backdrop-blur-md border border-accent/30">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 8l6 4-6 4V8z"/><circle cx="12" cy="12" r="10"/></svg>
                Watch on LinkedIn
              </span>
            </div>
          </a>
        </div>
      </div>
    </div>

  </section>

  <!-- Project Cursor Badge -->
  <div id="project-cursor-badge" style="display:none;" class="project-cursor-badge">
    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
      <path d="M8 5v14l11-7z" />
    </svg>
    <span>Open</span>
  </div>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to { opacity: 1; transform: translateY(0); }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }

  /* Project Cursor Badge */
  .project-cursor-badge {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    background-color: #ffffff;
    color: #000000;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
    will-change: transform, opacity;
  }
</style>

<script>
  const initCursorBadge = () => { return;
    const badge = document.getElementById('project-cursor-badge');
    const cards = document.querySelectorAll('.achievement-tile');
    if (!badge || cards.length === 0) return;

    let mouseX = 0, mouseY = 0;
    let badgeX = 0, badgeY = 0;
    let currentScale = 0.5, targetScale = 0.5;
    let currentOpacity = 0, targetOpacity = 0;

    const onMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    };
    window.addEventListener('mousemove', onMouseMove);

    cards.forEach(card => {
      card.addEventListener('mouseenter', () => { targetScale = 1; targetOpacity = 1; });
      card.addEventListener('mouseleave', () => { targetScale = 0.5; targetOpacity = 0; });
    });

    let animationFrameId: number;
    const animate = () => {
      badgeX = mouseX;
      badgeY = mouseY;
      currentScale += (targetScale - currentScale) * 0.15;
      currentOpacity += (targetOpacity - currentOpacity) * 0.15;

      badge.style.opacity = currentOpacity.toFixed(3);
      badge.style.transform = `translate3d(${badgeX}px, ${badgeY}px, 0) translate(-50%, -50%) scale(${currentScale.toFixed(3)})`;

      animationFrameId = requestAnimationFrame(animate);
    };
    animate();

    return () => {
      window.removeEventListener('mousemove', onMouseMove);
      cancelAnimationFrame(animationFrameId);
    };
  };

  let cleanupCursor: (() => void) | null = null;
  const setupAll = () => {
    if (cleanupCursor) cleanupCursor();
    cleanupCursor = initCursorBadge();
  };

  window.addEventListener('load', setupAll);
  document.addEventListener('astro:after-swap', setupAll);
  setupAll();
</script>
