---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/nav.astro';

const title = "CREATE Lab, EPFL";
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/#career" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <a href="https://www.epfl.ch/en/" target="_blank" rel="noopener noreferrer" class="achievement-tile block cursor-pointer">
        <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center hover:scale-105 transition-transform duration-300">
          <img src="/EPFL.png" alt={title} class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
        </div>
        <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30 group-hover:opacity-60 transition-opacity duration-500"></div>
      </a>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
      <p class="text-accent font-semibold mt-2 text-lg">Research Intern</p>
      <p class="text-gray text-sm mt-1">March 2026 - Present | Remote (Full-Time)</p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-3">
        <span class="bg-accent/10 border border-accent/20 text-accent px-4 py-1.5 rounded-full text-sm font-semibold">Supervisor: Prof. Josie Hughes</span>
        <span class="bg-accent/10 border border-accent/20 text-accent px-4 py-1.5 rounded-full text-sm font-semibold">Project: Open Parametric Hand (OPH)</span>
      </div>
      <div class="mt-4">
        <a href="/projects/oph" class="achievement-tile inline-flex items-center gap-2 text-accent hover:text-maintext transition-colors text-sm font-semibold border border-accent/20 rounded-full px-4 py-2 hover:bg-accent/10">
          View Open Parametric Hand Project
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">
    
    <!-- 2. About EPFL -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> About EPFL
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          École Polytechnique Fédérale de Lausanne (EPFL) is one of the world's premier institutions for science, engineering, and technology. Recognized among the Top 25 universities globally in the QS World University Rankings and Top 15 worldwide for Engineering & Technology, EPFL is renowned for its pioneering research, innovation ecosystem, and interdisciplinary collaborations. The university hosts hundreds of research laboratories and collaborates extensively with academia, industry, and healthcare organizations to develop technologies with global impact.
        </p>
      </div>
    </div>

    <!-- 3. About CREATE Lab -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> About CREATE Lab
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          The Computational Robot Design and Fabrication (CREATE) Lab, led by Prof. Josie Hughes, conducts cutting-edge research at the intersection of robotics, computational design, digital fabrication, and bio-inspired engineering. The lab focuses on developing next-generation robotic systems that are adaptable, accessible, and capable of addressing real-world challenges in healthcare, assistive technology, and human-robot interaction.
        </p>
      </div>
    </div>

    <!-- 4. Research Experience -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Research Experience
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-6">
        
        <div class="bg-accent/10 border-l-4 border-accent p-4 rounded-r-xl">
          <p class="text-maintext font-body text-base md:text-lg font-medium">
            <span class="text-xl mr-2">🚀</span> <strong class="text-accent">Ongoing Research & Publication:</strong> My research work is actively ongoing, and I am currently working towards publishing a paper in collaboration with EPFL. Additionally, I am deeply honored to be featured on the official <a href="https://sites.google.com/view/open-parametric-hand/projects/voice-and-gesture-control" target="_blank" rel="noopener noreferrer" class="text-accent font-bold hover:underline transition-colors">Open Parametric Hand project page</a> for my engineering contributions.
          </p>
        </div>

        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          As a Research Intern at CREATE Lab, I have been contributing to an R&D-intensive research project focused on the Open Parametric Hand (OPH) - an open-source initiative aimed at developing affordable, modular, and customizable prosthetic hands. Working closely with the research team, I have been involved in iterative design, collaborative engineering, and research-driven product development, gaining first-hand exposure to the methodologies and workflows followed in a globally recognized robotics laboratory.
        </p>
        <div class="flex items-center gap-3 text-accent text-sm md:text-base font-semibold border-t border-accent/10 pt-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
          <p>Technical implementation and engineering details are available on the dedicated Open Parametric Hand project page.</p>
        </div>
      </div>
    </div>

    <!-- 5. Research Impact -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Research Impact
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <ul class="space-y-4 text-gray font-body text-base md:text-lg list-none">
          <li class="flex items-start gap-4">
            <span>Contributed to an international open-source prosthetics initiative.</span>
          </li>
          <li class="flex items-start gap-4">
            <span>Worked directly within a research-driven robotics laboratory on an active development project.</span>
          </li>
          <li class="flex items-start gap-4">
            <span>Collaborated with researchers in an interdisciplinary engineering environment.</span>
          </li>
          <li class="flex items-start gap-4">
            <span>Gained experience in research methodology, product development, and design validation.</span>
          </li>
          <li class="flex items-start gap-4">
            <span>Strengthened my understanding of how robotics research is translated into real-world assistive healthcare technologies.</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- 6. Media & Featured -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Media & Featured
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          
          <a href="https://sites.google.com/view/open-parametric-hand/projects/voice-and-gesture-control" target="_blank" rel="noopener noreferrer" class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md block">
            <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/EPFL/oph website.png" alt="OPH Website" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">OPH Project</p>
              <p class="text-gray text-xs mt-1">Voice and Gesture Control</p>
            </div>
          </a>

          <a href="https://www.linkedin.com/posts/prof-dr-vibhav-kumar-sachan-275812121_heartiest-congratulations-to-arpita-kumari-ugcPost-7441107861465714688-6iCI?utm_source=social_share_send&utm_medium=member_desktop_web&rcm=ACoAAEYVexMBjaryTgP9mTSI1ewZJ0EclC9co7A" target="_blank" rel="noopener noreferrer" class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md block">
            <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/EPFL/kiet departmental post.png" alt="KIET Departmental Post" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Departmental Feature</p>
              <p class="text-gray text-xs mt-1">KIET Recognition</p>
            </div>
          </a>

          <a href="https://www.epfl.ch/about/" target="_blank" rel="noopener noreferrer" class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md block">
            <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/EPFL/aboutepfl.jpg" alt="EPFL" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">About EPFL</p>
              <p class="text-gray text-xs mt-1">École Polytechnique Fédérale de Lausanne</p>
            </div>
          </a>

          <a href="https://www.epfl.ch/labs/create/" target="_blank" rel="noopener noreferrer" class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md block">
            <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/EPFL/create lab.png" alt="CREATE Lab" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">CREATE Lab</p>
              <p class="text-gray text-xs mt-1">Research Laboratory</p>
            </div>
          </a>

          <a href="https://people.epfl.ch/josie.hughes?lang=en" target="_blank" rel="noopener noreferrer" class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md block">
            <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/EPFL/prof josie.png" alt="Prof Josie Hughes" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Prof. Josie Hughes</p>
              <p class="text-gray text-xs mt-1">Lab Director & Supervisor</p>
            </div>
          </a>

          <div class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/EPFL/The making process.jpg" alt="The Making Process" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">The Making Process</p>
              <p class="text-gray text-xs mt-1">Prototyping Phase</p>
            </div>
          </div>
          
          <div class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/EPFL/Testing with 9KG.jpg" alt="Testing with 9KG" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Load Testing</p>
              <p class="text-gray text-xs mt-1">9KG Validation</p>
            </div>
          </div>
          
          <div class="achievement-tile cursor-pointer group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Career/EPFL/Inventory.jpg" alt="Inventory" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Component Inventory</p>
              <p class="text-gray text-xs mt-1">Hardware Organization</p>
            </div>
          </div>
          
        </div>
      </div>
    </div>
  </section>

  <!-- Project Cursor Badge -->
  <div id="project-cursor-badge" class="project-cursor-badge">
    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
      <path d="M8 5v14l11-7z" />
    </svg>
    <span>Open</span>
  </div>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to { opacity: 1; transform: translateY(0); }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }

  /* Project Cursor Badge */
  .project-cursor-badge {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    background-color: #ffffff;
    color: #000000;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
    will-change: transform, opacity;
  }
</style>

<script>
  const initCursorBadge = () => {
    const badge = document.getElementById('project-cursor-badge');
    const cards = document.querySelectorAll('.achievement-tile');
    if (!badge || cards.length === 0) return;

    let mouseX = 0, mouseY = 0;
    let badgeX = 0, badgeY = 0;
    let currentScale = 0.5, targetScale = 0.5;
    let currentOpacity = 0, targetOpacity = 0;

    const onMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    };
    window.addEventListener('mousemove', onMouseMove);

    cards.forEach(card => {
      card.addEventListener('mouseenter', () => { targetScale = 1; targetOpacity = 1; });
      card.addEventListener('mouseleave', () => { targetScale = 0.5; targetOpacity = 0; });
    });

    let animationFrameId: number;
    const animate = () => {
      badgeX += (mouseX - badgeX) * 0.15;
      badgeY += (mouseY - badgeY) * 0.15;
      currentScale += (targetScale - currentScale) * 0.15;
      currentOpacity += (targetOpacity - currentOpacity) * 0.15;

      badge.style.opacity = currentOpacity.toFixed(3);
      badge.style.transform = `translate3d(${badgeX}px, ${badgeY}px, 0) translate(-50%, -50%) scale(${currentScale.toFixed(3)})`;

      animationFrameId = requestAnimationFrame(animate);
    };
    animate();

    return () => {
      window.removeEventListener('mousemove', onMouseMove);
      cancelAnimationFrame(animationFrameId);
    };
  };

  let cleanupCursor: (() => void) | null = null;
  const setupAll = () => {
    if (cleanupCursor) cleanupCursor();
    cleanupCursor = initCursorBadge();
  };

  window.addEventListener('load', setupAll);
  document.addEventListener('astro:after-swap', setupAll);
  setupAll();
</script>
