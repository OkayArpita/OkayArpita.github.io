---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/nav.astro';

const title = "e-Yantra 2024-25 Competition Details";
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/achievements/e-yantra" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
        <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <a href="https://www.e-yantra.org/" target="_blank" rel="noopener noreferrer" class="block cursor-pointer achievement-tile">
        <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center hover:scale-105 transition-transform duration-300">
          <img src="/eYantra.png" alt={title} class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
        </div>
        <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30 group-hover:opacity-60 transition-opacity duration-500"></div>
      </a>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-maintext tracking-tight mt-6">
        e-Yantra Robotics Competition 2024-25
      </h1>
      <p class="text-accent font-semibold mt-2">International 4th Rank | Balancing Builder (BB) Theme</p>
      <div class="mt-4">
        <a href="/projects/balancing-bot" class="achievement-tile inline-flex items-center gap-2 text-accent hover:text-maintext transition-colors text-sm font-semibold border border-accent/20 rounded-full px-4 py-2 hover:bg-accent/10">
          View the Balancing Builder Project
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">

    <!-- Achievement -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Achievement
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Secured <strong>4th Rank Internationally</strong> in the e-Yantra Robotics Competition (eYRC) 2024-25, organized by the Department of Computer Science & Engineering, IIT Bombay, under the e-Yantra Project, an initiative of the Ministry of Education, Government of India.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Developed a two-wheeled self-balancing mobile manipulator for the Balancing Builder (BB) theme, combining control systems, embedded electronics, and autonomous robotics.
        </p>
      </div>
    </div>

    <!-- About the Competition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> About the Competition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          The 2024-25 Balancing Builder (BB) theme was set in a smart city environment, where participants developed a self-balancing mobile manipulator capable of transporting construction materials for residential infrastructure. The robot was required to maintain dynamic stability while autonomously navigating the arena and performing pick-and-place operations, simulating real-world material handling in congested urban environments.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          The competition followed a structured multi-stage evaluation process with rigorous technical assessments, standardized hardware specifications, and strict originality and plagiarism checks.
        </p>
      </div>
    </div>

    <!-- Competition Journey -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Competition Journey
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-6">
        
        <div class="space-y-2">
          <h3 class="text-lg font-heading font-bold text-accent">Stage 1 - Design & Simulation</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            A total of 1008 teams participated in the Balancing Builder theme. The first stage focused on mathematical modelling, control system design, and simulation of the self-balancing robot. Teams completed a series of milestone tasks demonstrating stable balancing, autonomous navigation, and manipulator control through simulation. Based on their overall performance, the top-performing teams advanced to the hardware round.
          </p>
        </div>

        <div class="border-t border-accent/10 pt-4 mt-4 space-y-2">
          <h3 class="text-lg font-heading font-bold text-accent">Stage 2 - Hardware Development</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Teams qualifying for Stage 2 received an official hardware development kit from IIT Bombay to build the robot under standardized hardware specifications and dimensional constraints. The focus shifted to designing, fabricating, assembling, and tuning a complete self-balancing robot capable of performing balancing, navigation, and autonomous pick-and-place tasks within the competition arena. Following hardware evaluation, our team advanced to the Grand Finale as one of the Top 5 finalist teams, where the robot completed the final competition run before the judging panel.
          </p>
        </div>

      </div>
    </div>

    <!-- Challenge -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Challenge
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Design and develop a two-wheeled self-balancing robot based on the inverted pendulum model, capable of maintaining stability while autonomously navigating the arena and manipulating construction blocks.
        </p>
        
        <div class="border-t border-accent/10 pt-4 mt-2">
          <p class="text-maintext font-heading font-semibold text-base mb-2">My primary contributions included:</p>
          <ul class="list-disc pl-6 space-y-2 text-gray font-body text-base">
            <li>Mathematical modelling of the balancing system</li>
            <li>LQR controller design and tuning using MATLAB</li>
            <li>Simulation and validation in CoppeliaSim</li>
            <li>CAD modelling and mechanical design</li>
            <li>Robot fabrication and assembly</li>
            <li>Embedded electronics and IMU integration</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Result & Recognition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Result & Recognition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <ul class="list-none space-y-3">
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">🏆</span> <span><strong>Ranked 4th Internationally</strong> among 1008 participating teams.</span>
          </li>
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">🏁</span> <span>Advanced to the Grand Finale as one of the <strong>Top 5 finalist teams</strong>.</span>
          </li>
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">💰</span> <span>Awarded a cash prize of <strong>₹20,000</strong>.</span>
          </li>
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">🍫</span> <span>Won the Post-Finale Robot Race, receiving <strong>Ferrero Rocher</strong> as the winner's prize.</span>
          </li>
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">🛠️</span> <span>Successfully developed a complete autonomous self-balancing robotic platform under IIT Bombay's e-Yantra program.</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Gallery -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Gallery
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          
          <!-- Practice Session Run (Video) -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black flex items-center justify-center p-2 relative">
              <video class="max-w-full max-h-full object-contain" controls preload="metadata" playsinline>
                <source src="/Achievements/eyrc24-25/practice%20session.mp4" type="video/mp4" />
              </video>
              <!-- Fullscreen Button -->
              <button class="absolute top-2 right-2 z-20 bg-black/60 hover:bg-accent/80 text-white rounded-lg p-2 transition-colors duration-300 fullscreen-btn" title="Toggle Fullscreen">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-white"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>
              </button>
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">Practice Session Run</p>
              <p class="text-gray text-xs mt-1">Balancing bot navigating the practice arena track (played directly inline)</p>
            </div>
          </div>

          <!-- e-Yantra 2024-25 Finalists -->
          <a href="https://eyrc24.e-yantra.org/finale" target="_blank" class="achievement-tile group block overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Achievements/eyrc24-25/e-Yantra%202024-25%20finalists.jpeg" alt="e-Yantra 2024-25 Finalists" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm flex items-center justify-between gap-2">
                <span>e-Yantra 2024-25 Finalists</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </p>
              <p class="text-gray text-xs mt-1">Finalist teams gathered at IIT Bombay during the event</p>
              <span class="text-accent text-[11px] block mt-1.5 font-mono break-all">eyrc24.e-yantra.org/finale</span>
            </div>
          </a>

          <!-- With Prof. Kavi Arya -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Achievements/eyrc24-25/with%20eyantra%20founder%20-%20prof%20kavi%20arya.jpg" alt="With Prof. Kavi Arya" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">With e-Yantra Founder</p>
              <p class="text-gray text-xs mt-1">Group photo with Prof. Kavi Arya, the founder of e-Yantra</p>
            </div>
          </div>

          <!-- Jury Panel Intro -->
          <a href="https://www.youtube.com/live/CZcLTQ4iBYg?si=kvdyX-_MqZRNfXzb&t=19588" target="_blank" class="achievement-tile group block overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Achievements/eyrc24-25/viva%20at%20finale.JPG" alt="Jury Panel Intro" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm flex items-center justify-between gap-2">
                <span>Jury Panel Intro</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </p>
              <p class="text-gray text-xs mt-1">Technical viva-voce and evaluation of our robot design by judges</p>
              <span class="text-accent text-[11px] block mt-1.5 font-mono break-all">youtube.com/live/CZcLTQ4iBYg</span>
            </div>
          </a>

          <!-- BB Finalists Lineup -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Achievements/eyrc24-25/bb%20finalists.JPG" alt="Balancing Builder Finalists" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">BB Finalists Lineup</p>
              <p class="text-gray text-xs mt-1">Balancing Builder theme finalists on stage at IIT Bombay</p>
            </div>
          </div>

          <!-- Felicitation Ceremony -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Achievements/eyrc24-25/felicitation.JPG" alt="Felicitation Ceremony" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">Felicitation Ceremony</p>
              <p class="text-gray text-xs mt-1">Receiving the official awards during the valedictory session</p>
            </div>
          </div>

          <!-- Mementos & Goodies -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Achievements/eyrc24-25/goodies.jpg" alt="Mementos & Goodies" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">Mementos & Goodies</p>
              <p class="text-gray text-xs mt-1">The certificates, medals, bags, and goodies won by our team</p>
            </div>
          </div>

          <!-- Grand Finale Arena Setup -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Achievements/eyrc24-25/final%20run.JPG" alt="Grand Finale Arena Setup" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">Grand Finale Arena Setup</p>
              <p class="text-gray text-xs mt-1">Preparing our self-balancing robot for the final runs inside the arena</p>
            </div>
          </div>

          <!-- All Robots Lineup -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Achievements/eyrc24-25/all%20the%20bot%20line%20following%20competetion.JPG" alt="All Robots Lineup" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">Robots Lineup</p>
              <p class="text-gray text-xs mt-1">Lineup of participating self-balancing mobile manipulators</p>
            </div>
          </div>

          <!-- Live Run Moment -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Achievements/eyrc24-25/Live%20run.jpg" alt="Live Run Moment" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">Live Run Moment</p>
              <p class="text-gray text-xs mt-1">Live tracking screen display showing path navigation and state logs</p>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Media & Featured -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Media & Featured
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-8">
        
        <!-- Official Documents -->
        <div class="space-y-4">
          <h3 class="text-lg font-heading font-bold text-maintext">Official Documents</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <a href="/Projects/BalancingBuilderBot/eYRC24_Certificate_1.jpg" target="_blank" class="achievement-tile group block overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
              <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
                <img src="/Projects/BalancingBuilderBot/eYRC24_Certificate_1.jpg" alt="eYRC Certificate of Completion" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
              </div>
              <div class="p-4 border-t border-accent/5">
                <p class="text-maintext font-heading font-bold text-sm flex items-center justify-between gap-2">
                  <span>Championship Certificate</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </p>
                <p class="text-gray text-xs mt-1">Official merit certificate for achieving 4th rank internationally</p>
              </div>
            </a>

            <a href="/Projects/BalancingBuilderBot/eYRC24_Certificate_2.png" target="_blank" class="achievement-tile group block overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
              <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
                <img src="/Projects/BalancingBuilderBot/eYRC24_Certificate_2.png" alt="Level of Certificate" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
              </div>
              <div class="p-4 border-t border-accent/5">
                <p class="text-maintext font-heading font-bold text-sm flex items-center justify-between gap-2">
                  <span>Level of Certificate</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </p>
                <p class="text-gray text-xs mt-1">Certificate indicating the final level of merit achieved</p>
              </div>
            </a>

            <!-- Embedded Theme Film Video inside Official Documents -->
            <div class="group block overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
              <div class="aspect-[4/3] w-full overflow-hidden bg-black flex items-center justify-center p-2 relative">
                <video class="max-w-full max-h-full object-contain" controls preload="metadata" playsinline>
                  <source src="/Achievements/eyrc24-25/Theme%20Film.mp4" type="video/mp4" />
