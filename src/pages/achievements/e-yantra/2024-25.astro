---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/nav.astro';

const title = "e-Yantra 2024-25 Competition Details";
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/achievements/e-yantra" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center">
        <img src="/eYantra.png" alt={title} class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
      <div class="mt-4">
        <a href="/projects/balancing-bot" class="inline-flex items-center gap-2 text-accent hover:text-maintext transition-colors text-sm font-semibold border border-accent/20 rounded-full px-4 py-2 hover:bg-accent/10">
          View the Balancing Builder Project Page
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">

    
    <!-- Achievement -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Achievement
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">Developed a two-wheeled self-balancing robot (Balancing Builder Bot) for the e-Yantra Robotics Competition (eYRC 2024-25).</p>
      </div>
    </div>

    <!-- About the Competition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> About the Competition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">e-Yantra is an international robotics outreach program hosted by IIT Bombay. The competition challenges students to solve real-world problems using robotics, embedded systems, and control theory.</p>
      </div>
    </div>

    <!-- Challenge -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Challenge
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">Integrated inverted-pendulum dynamics, IMU-based state estimation, and an autonomous pick-and-place mechanism themed for smart-city infrastructure applications. Implemented LQR-based stabilization in MATLAB with CoppeliaSim simulation, followed by CAD, fabrication, and integration.</p>
      </div>
    </div>

    <!-- Result & Recognition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Result & Recognition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">Secured 4th position internationally among 1008 teams, earning a cash prize of ₹20,000 (≈ CHF 206).</p>
      </div>
    </div>

    <!-- Gallery -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Gallery
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed text-center italic opacity-75">
          Images and photos from the event will be displayed here.
        </p>
      </div>
    </div>

    <!-- Media & Featured -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Media & Featured
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Links to media coverage, articles, or featured posts related to this achievement.
        </p>
      </div>
    </div>


  </section>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }
</style>
