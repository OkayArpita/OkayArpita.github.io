---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/nav.astro';

const title = "e-Yantra 2025-26 Competition Details";
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/achievements/e-yantra" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center">
        <img src="/eYantra.png" alt={title} class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-maintext tracking-tight mt-6">
        e-Yantra Robotics Competition 2025-26
      </h1>
      <p class="text-accent font-semibold mt-2">International Top 10 Rank | MazeSolver Bot Theme</p>
      <div class="mt-4">
        <a href="/projects/maze-solver" class="achievement-tile inline-flex items-center gap-2 text-accent hover:text-maintext transition-colors text-sm font-semibold border border-accent/20 rounded-full px-4 py-2 hover:bg-accent/10">
          View the MazeSolver Bot Project
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">

    <!-- Achievement -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Achievement
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Secured an **International Top 10 Rank** in the e-Yantra Robotics Competition (eYRC) 2025-26, organized by the Department of Computer Science & Engineering, IIT Bombay, under the e-Yantra Project, an initiative sponsored by the Ministry of Education, Government of India.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Developed an FPGA-based autonomous robot for the MazeSolver Bot (MB) theme, designed for intelligent warehouse navigation and environmental monitoring.
        </p>
      </div>
    </div>

    <!-- About the Competition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> About the Competition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          The e-Yantra Robotics Competition (eYRC) is IIT Bombay's flagship international robotics competition that trains students in embedded systems, digital hardware design, and autonomous robotics through a structured multi-stage learning framework.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          The 2025-26 MazeSolver Bot (MB) theme focused on post-harvest agricultural warehouse automation, where teams designed a fully autonomous FPGA-powered robot capable of navigating dynamically changing warehouse layouts while monitoring temperature, humidity, and soil moisture.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Unlike conventional robotics competitions, teams were required to build the complete robot - from digital hardware architecture to embedded electronics - while adhering to strict design specifications, originality guidelines, and plagiarism checks.
        </p>
      </div>
    </div>

    <!-- Competition Journey -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Competition Journey
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-6">
        
        <div class="space-y-2">
          <h3 class="text-lg font-heading font-bold text-accent">Stage 1 - Design & Simulation</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            A total of 682 teams participated in the MazeSolver Bot theme. Teams completed a series of simulation tasks, technical assessments, and milestone submissions. Based on their overall performance, only the top 50-100 teams qualified for the hardware stage. Qualified teams received an official hardware development kit from IIT Bombay and proceeded to build the robot under predefined hardware specifications and dimensional constraints.
          </p>
        </div>

        <div class="border-t border-accent/10 pt-4 mt-4 space-y-2">
          <h3 class="text-lg font-heading font-bold text-accent">Stage 2 - Hardware Implementation</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            The competition transitioned to complete robot development using the provided DE0-Nano FPGA platform and standardized hardware kit. Teams were required to design, fabricate, assemble, and validate a fully autonomous robot capable of real-time maze navigation and environmental sensing while complying with strict hardware guidelines, documentation standards, and originality checks.
          </p>
        </div>

      </div>
    </div>

    <!-- Challenge -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Challenge
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Design and develop a fully autonomous FPGA-based robot capable of solving an unknown warehouse maze while collecting environmental data in real time.
        </p>
        
        <div class="border-t border-accent/10 pt-4 mt-2">
          <p class="text-maintext font-heading font-semibold text-base mb-2">My primary contributions included:</p>
          <ul class="list-disc pl-6 space-y-2 text-gray font-body text-base">
            <li><strong>Mechanical Design:</strong> Formulated robot structure and sensor mounting systems in Autodesk Fusion 360.</li>
            <li><strong>Chassis & Sensor Mechanism Development:</strong> Rapidly prototyped components via 3D printing and managed physical assembly.</li>
            <li><strong>Electronic Integration:</strong> Routed a custom PCB breakout board using KiCad for sensor interfacing and signal routing.</li>
            <li><strong>FPGA Integration:</strong> Programmed logic elements and interface blocks on the DE0-Nano FPGA kit.</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Result & Recognition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Result & Recognition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <ul class="list-none space-y-3">
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">🏆</span> <span><strong>Ranked 10th Internationally</strong> among 682 participating teams.</span>
          </li>
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">🚀</span> <span>Qualified for the Stage 2 Hardware Round.</span>
          </li>
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">🛠️</span> <span>Successfully developed a complete FPGA-based autonomous robotic platform under IIT Bombay's e-Yantra program.</span>
          </li>
    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
      <path d="M8 5v14l11-7z" />
    </svg>
    <span>Open</span>
  </div>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }

  /* Project Cursor Badge */
  .project-cursor-badge {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    background-color: #ffffff;
    color: #000000;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
    will-change: transform, opacity;
  }
</style>

<script>
  const initCursorBadge = () => {
    const badge = document.getElementById('project-cursor-badge');
    const cards = document.querySelectorAll('.achievement-tile');
    if (!badge || cards.length === 0) return;

    let mouseX = 0;
    let mouseY = 0;
    let badgeX = 0;
    let badgeY = 0;
    let currentScale = 0.5;
    let targetScale = 0.5;
    let currentOpacity = 0;
    let targetOpacity = 0;
    let isHovering = false;

    // Track mouse coordinates globally
    const onMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    };

    window.addEventListener('mousemove', onMouseMove);

    // Mouse entering and leaving cards
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        isHovering = true;
        targetScale = 1;
        targetOpacity = 1;
      });

      card.addEventListener('mouseleave', () => {
        isHovering = false;
        targetScale = 0.5;
        targetOpacity = 0;
      });
    });

    let animationFrameId: number;

    const animate = () => {
      // Smoothen coordinates with a LERP factor (0.15)
      const dx = mouseX - badgeX;
      const dy = mouseY - badgeY;
      badgeX += dx * 0.15;
      badgeY += dy * 0.15;

      // Smoothen scale and opacity
      currentScale += (targetScale - currentScale) * 0.15;
      currentOpacity += (targetOpacity - currentOpacity) * 0.15;

      badge.style.opacity = currentOpacity.toFixed(3);
      badge.style.transform = `translate3d(${badgeX}px, ${badgeY}px, 0) translate(-50%, -50%) scale(${currentScale.toFixed(3)})`;

      animationFrameId = requestAnimationFrame(animate);
    };

    animate();

    // Return cleanup function to run on navigation/unmount
    return () => {
      window.removeEventListener('mousemove', onMouseMove);
      cancelAnimationFrame(animationFrameId);
    };
  };

  const setupFullscreen = () => {
    const btns = document.querySelectorAll('.fullscreen-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const container = btn.parentElement;
        if (!container) return;
        if (!document.fullscreenElement) {
          container.requestFullscreen().catch(err => {
            console.error("Error attempting to enable fullscreen:", err);
          });
        } else {
          document.exitFullscreen();
        }
      });
    });
  };

  let cleanupCursor: (() => void) | null = null;

  const setupAll = () => {
    if (cleanupCursor) {
      cleanupCursor();
    }
    cleanupCursor = initCursorBadge();
    setupFullscreen();
  };

  window.addEventListener('load', setupAll);
  document.addEventListener('astro:after-swap', setupAll);
  setupAll();
</script>
