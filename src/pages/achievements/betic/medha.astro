              <div class="aspect-[4/3] w-full overflow-hidden">
                <img src="/Achievements/medha/medha-2024-best-innovation-certificate.jpg" alt="Best Innovation Award Certificate" class="w-full h-full object-contain p-2 bg-white group-hover:scale-105 transition-transform duration-700" />
              </div>
              <div class="p-4 border-t border-accent/5">
