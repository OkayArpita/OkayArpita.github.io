---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/nav.astro';

const title = "Medical Device Hackathon (MEDHA 2024)";
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/achievements/betic" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center">
        <img src="/BETIC.png" alt={title} class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
      <p class="text-accent font-semibold mt-2">🏆 Best Innovation Award Winner</p>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">

    <!-- About the Competition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> About the Competition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          <strong>Medical Device Hackathon (MEDHA)</strong> is BETIC's flagship 36-hour innovation hackathon that introduces participants to need-driven medical device development. Multidisciplinary teams work on real clinical problem statements provided by doctors and rapidly prototype practical engineering solutions under expert mentorship.
        </p>
      </div>
    </div>

    <!-- Challenge -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Challenge
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed font-semibold text-maintext">
          Our team was assigned the clinical challenge:
        </p>
        <blockquote class="border-l-4 border-accent pl-4 py-1 italic text-accent font-heading text-lg md:text-xl my-4">
          "Design a portable device for back pain relief."
        </blockquote>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Instead of designing only a pain-relief device, we proposed a preventive wearable that combined posture monitoring, real-time corrective feedback, and therapeutic vibration into a single rehabilitation platform.
        </p>
      </div>
    </div>

    <!-- Result & Recognition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Result & Recognition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-6">
        <div class="flex items-start gap-4">
          <span class="text-2xl mt-1">🏆</span>
          <div>
            <h4 class="text-lg md:text-xl font-heading font-bold text-maintext">Best Innovation Award</h4>
            <p class="text-gray font-body text-base mt-1">Recognized for outstanding innovation and technical execution among competitive ideas.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4">
          <span class="text-2xl mt-1">🚀</span>
          <div>
            <h4 class="text-lg md:text-xl font-heading font-bold text-maintext">Posture Pro Belt Proof-of-Concept</h4>
            <p class="text-gray font-body text-base mt-1">Developed the first working proof-of-concept of the belt under the 36-hour constraint.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <span class="text-2xl mt-1">🎯</span>
          <div>
            <h4 class="text-lg md:text-xl font-heading font-bold text-maintext">MEDIC 2024 Selection</h4>
            <p class="text-gray font-body text-base mt-1">Selected as one of only two teams to continue development through the MEDIC 2024 Medical Device Innovation Program.</p>
          </div>
        </div>

        <div class="border-t border-accent/10 pt-4 mt-2">
          <p class="text-accent font-semibold italic text-base md:text-lg">
            This marked the transition from a hackathon prototype to a structured product development journey.
          </p>
        </div>
      </div>
    </div>

    <!-- Pitch Video & Presentation -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Pitch & Presentation
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Pitch Video -->
        <div class="bg-accent/5 border border-accent/10 rounded-2xl p-4 md:p-6 space-y-3 flex flex-col justify-between">
          <div>
            <h3 class="text-lg md:text-xl font-heading font-bold text-maintext mb-2">Pitch Video</h3>
            <p class="text-gray font-body text-sm mb-4">Watch the pitch video for the Posture Pro Belt submitted during MEDHA 2024.</p>
          </div>
          <div class="w-full aspect-video rounded-xl overflow-hidden border border-accent/20 bg-black">
            <video controls class="w-full h-full object-contain">
              <source src="/Achievements/medha/my-pitch.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>

        <!-- Pitch Presentation -->
        <a 
          href="/Achievements/medha/project-presentation.pdf" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="achievement-tile bg-accent/5 border border-accent/10 rounded-2xl p-4 md:p-6 space-y-3 flex flex-col justify-between hover:border-accent/40 transition-all duration-500 group"
        >
          <div>
            <h3 class="text-lg md:text-xl font-heading font-bold text-maintext mb-2 flex items-center justify-between gap-2">
              <span>Project Presentation</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </h3>
            <p class="text-gray font-body text-sm mb-4">Click to view the full pitch presentation slides outlining the clinical challenge, mechanics, and design.</p>
          </div>
          <div class="w-full aspect-video rounded-xl overflow-hidden border border-accent/20 bg-background/30 flex flex-col items-center justify-center p-6 gap-3 group-hover:bg-accent/5 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:scale-110 transition-transform duration-500"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            <span class="font-heading font-semibold text-sm text-maintext">Open Presentation PDF</span>
            <span class="text-xs text-gray">Opens in fullscreen new tab</span>
          </div>
        </a>
      </div>
    </div>

    <!-- Gallery -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Gallery
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Team -->
        <div class="bg-accent/5 border border-accent/10 rounded-2xl overflow-hidden hover:border-accent/30 transition-all duration-300 group flex flex-col">
          <div class="aspect-video w-full overflow-hidden bg-black/20 border-b border-accent/10">
            <img src="/Projects/PostureProBelt/MEDHA 2024 (Ar)_page-0001.jpg" alt="Team Posture Pro Belt" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
          </div>
          <div class="p-4 flex-grow flex flex-col justify-center">
            <h4 class="font-heading font-semibold text-maintext text-base">Team</h4>
            <p class="text-xs text-gray mt-1">Our multidisciplinary engineering and clinical team at MEDHA 2024.</p>
          </div>
        </div>

        <!-- Prototype -->
        <div class="bg-accent/5 border border-accent/10 rounded-2xl overflow-hidden hover:border-accent/30 transition-all duration-300 group flex flex-col">
          <div class="aspect-video w-full overflow-hidden bg-black/20 border-b border-accent/10">
            <img src="/Projects/PostureProBelt/medha prototype and concept.png" alt="Posture Pro Belt Prototype" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
          </div>
          <div class="p-4 flex-grow flex flex-col justify-center">
            <h4 class="font-heading font-semibold text-maintext text-base">Prototype</h4>
            <p class="text-xs text-gray mt-1">Initial 3-in-1 posture belt concept showing sensor placement and massage nodes.</p>
          </div>
        </div>

        <!-- Demonstration -->
        <div class="bg-accent/5 border border-accent/10 rounded-2xl overflow-hidden hover:border-accent/30 transition-all duration-300 group flex flex-col">
          <div class="aspect-video w-full overflow-hidden bg-black border-b border-accent/10 flex items-center justify-center relative">
            <video class="w-full h-full object-contain" muted loops playsinline>
              <source src="/Projects/PostureProBelt/medhaDemo.mp4" type="video/mp4" />
            </video>
            <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-100 group-hover:opacity-0 transition-opacity duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><polygon points="6 3 20 12 6 21 6 3"/></svg>
            </div>
            <a href="/Projects/PostureProBelt/medhaDemo.mp4" target="_blank" class="absolute inset-0 z-10"></a>
          </div>
          <div class="p-4 flex-grow flex flex-col justify-center">
            <h4 class="font-heading font-semibold text-maintext text-base">Demonstration</h4>
            <p class="text-xs text-gray mt-1">Live demo of real-time posture vibration alert and motor activation.</p>
          </div>
        </div>

        <!-- Award Ceremony -->
        <div class="bg-accent/5 border border-accent/10 rounded-2xl overflow-hidden hover:border-accent/30 transition-all duration-300 group flex flex-col">
          <div class="aspect-video w-full overflow-hidden bg-black/20 border-b border-accent/10">
            <img src="/Projects/PostureProBelt/MEDIC 2024.jpg" alt="Award Ceremony" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
          </div>
          <div class="p-4 flex-grow flex flex-col justify-center">
            <h4 class="font-heading font-semibold text-maintext text-base">Award Ceremony</h4>
            <p class="text-xs text-gray mt-1">Receiving the Best Innovation Award and certificate at the valedictory session.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Media & Featured -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Media & Featured
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <!-- MEDHA Brochure -->
          <a href="/Achievements/medha/project-presentation.pdf" target="_blank" class="achievement-tile flex items-center justify-between p-4 bg-background/50 border border-accent/10 rounded-xl hover:border-accent/40 hover:bg-accent/5 transition-all duration-300 group">
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
              <span class="font-heading font-semibold text-sm text-maintext">MEDHA Brochure</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>

          <!-- BETIC Website -->
          <a href="https://betic.in" target="_blank" rel="noopener noreferrer" class="achievement-tile flex items-center justify-between p-4 bg-background/50 border border-accent/10 rounded-xl hover:border-accent/40 hover:bg-accent/5 transition-all duration-300 group">
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <span class="font-heading font-semibold text-sm text-maintext">BETIC Website</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>

          <!-- College News & Social Media -->
          <a href="https://www.linkedin.com/school/betic-iitb/" target="_blank" rel="noopener noreferrer" class="achievement-tile flex items-center justify-between p-4 bg-background/50 border border-accent/10 rounded-xl hover:border-accent/40 hover:bg-accent/5 transition-all duration-300 group">
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              <span class="font-heading font-semibold text-sm text-maintext">News & Social Media</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>

  </section>

  <!-- Project Cursor Badge -->
  <div id="project-cursor-badge" class="project-cursor-badge">
    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
      <path d="M8 5v14l11-7z" />
    </svg>
    <span>Open</span>
  </div>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }

  /* Project Cursor Badge */
  .project-cursor-badge {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    background-color: #ffffff;
    color: #000000;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
    will-change: transform, opacity;
  }
</style>

<script>
  const initCursorBadge = () => {
    const badge = document.getElementById('project-cursor-badge');
    const cards = document.querySelectorAll('.achievement-tile');
    if (!badge || cards.length === 0) return;

    let mouseX = 0;
    let mouseY = 0;
    let badgeX = 0;
    let badgeY = 0;
    let currentScale = 0.5;
    let targetScale = 0.5;
    let currentOpacity = 0;
    let targetOpacity = 0;
    let isHovering = false;

    // Track mouse coordinates globally
    const onMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    };

    window.addEventListener('mousemove', onMouseMove);

    // Mouse entering and leaving cards
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        isHovering = true;
        targetScale = 1;
        targetOpacity = 1;
      });

      card.addEventListener('mouseleave', () => {
        isHovering = false;
        targetScale = 0.5;
        targetOpacity = 0;
      });
    });

    let animationFrameId: number;

    const animate = () => {
      // Smoothen coordinates with a LERP factor (0.15)
      const dx = mouseX - badgeX;
      const dy = mouseY - badgeY;
      badgeX += dx * 0.15;
      badgeY += dy * 0.15;

      // Smoothen scale and opacity
      currentScale += (targetScale - currentScale) * 0.15;
      currentOpacity += (targetOpacity - currentOpacity) * 0.15;

      badge.style.opacity = currentOpacity.toFixed(3);
      badge.style.transform = `translate3d(${badgeX}px, ${badgeY}px, 0) translate(-50%, -50%) scale(${currentScale.toFixed(3)})`;

      animationFrameId = requestAnimationFrame(animate);
    };

    animate();

    // Return cleanup function to run on navigation/unmount
    return () => {
      window.removeEventListener('mousemove', onMouseMove);
      cancelAnimationFrame(animationFrameId);
    };
  };

  let cleanupCursor: (() => void) | null = null;

  const setupAll = () => {
    if (cleanupCursor) {
      cleanupCursor();
    }
    cleanupCursor = initCursorBadge();
  };

  window.addEventListener('load', setupAll);
  document.addEventListener('astro:after-swap', setupAll);
  setupAll();
</script>

