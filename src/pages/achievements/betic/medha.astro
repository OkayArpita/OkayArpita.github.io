---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/nav.astro';

const title = "Medical Device Hackathon (MEDHA 2024)";
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/achievements/betic" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center">
        <img src="/BETIC.png" alt={title} class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
      <p class="text-accent font-semibold mt-2">🏆 Best Innovation Award Winner</p>
      <div class="mt-4">
        <a href="/projects/posture-belt" class="achievement-tile inline-flex items-center gap-2 text-accent hover:text-maintext transition-colors text-sm font-semibold border border-accent/20 rounded-full px-4 py-2 hover:bg-accent/10">
          View the Posture Belt Project
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">

    <!-- About the Competition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> About the Competition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          <strong>Medical Device Hackathon (MEDHA)</strong> is BETIC's flagship 36-hour innovation hackathon that introduces participants to need-driven medical device development. Multidisciplinary teams work on real clinical problem statements provided by doctors and rapidly prototype practical engineering solutions under expert mentorship.
        </p>
      </div>
    </div>

    <!-- Challenge -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Challenge
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed font-semibold text-maintext">
          Our team was assigned the clinical challenge:
        </p>
        <blockquote class="border-l-4 border-accent pl-4 py-1 italic text-accent font-heading text-lg md:text-xl my-4">
          "Design a portable device for back pain relief."
        </blockquote>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Instead of designing only a pain-relief device, we proposed a preventive wearable that combined posture monitoring, real-time corrective feedback, and therapeutic vibration into a single rehabilitation platform.
        </p>
      </div>
    </div>

    <!-- Result & Recognition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Result & Recognition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-6">
        <div class="flex items-start gap-4">
          <span class="text-2xl mt-1">🏆</span>
          <div>
            <h4 class="text-lg md:text-xl font-heading font-bold text-maintext">Best Innovation Award</h4>
            <p class="text-gray font-body text-base mt-1">Recognized for outstanding innovation and technical execution among competitive ideas.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4">
          <span class="text-2xl mt-1">🚀</span>
          <div>
            <h4 class="text-lg md:text-xl font-heading font-bold text-maintext">Posture Pro Belt Proof-of-Concept</h4>
            <p class="text-gray font-body text-base mt-1">Developed the first working proof-of-concept of the belt under the 36-hour constraint.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <span class="text-2xl mt-1">🎯</span>
          <div>
            <h4 class="text-lg md:text-xl font-heading font-bold text-maintext">MEDIC 2024 Selection</h4>
            <p class="text-gray font-body text-base mt-1">Selected as one of only two teams to continue development through the MEDIC 2024 Medical Device Innovation Program.</p>
          </div>
        </div>

        <div class="border-t border-accent/10 pt-4 mt-2">
          <p class="text-accent font-semibold italic text-base md:text-lg">
            This marked the transition from a hackathon prototype to a structured product development journey.
          </p>
        </div>
      </div>
    </div>

    <!-- Pitch Video & Presentation -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Pitch & Presentation
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Pitch Video -->
        <div class="bg-accent/5 border border-accent/10 rounded-2xl p-4 md:p-6 space-y-3 flex flex-col justify-between">
          <div>
            <h3 class="text-lg md:text-xl font-heading font-bold text-maintext mb-2">Pitch Video</h3>
            <p class="text-gray font-body text-sm mb-4">Watch the pitch video for the Posture Pro Belt submitted during MEDHA 2024.</p>
          </div>
          <div class="w-full aspect-video rounded-xl overflow-hidden border border-accent/20 bg-black">
            <video controls playsinline class="w-full h-full object-contain">
              <source src="/Achievements/medha/my-pitch.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>

        <!-- Pitch Presentation -->
        <a 
          href="/Achievements/medha/project-presentation.pdf" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="achievement-tile bg-accent/5 border border-accent/10 rounded-2xl p-4 md:p-6 space-y-3 flex flex-col justify-between hover:border-accent/40 transition-all duration-500 group"
        >
          <div>
            <h3 class="text-lg md:text-xl font-heading font-bold text-maintext mb-2 flex items-center justify-between gap-2">
              <span>Project Presentation</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </h3>
            <p class="text-gray font-body text-sm mb-4">Click to view the full pitch presentation slides outlining the clinical challenge, mechanics, and design.</p>
          </div>
          <div class="w-full aspect-video rounded-xl overflow-hidden border border-accent/20 bg-black/40 flex flex-col items-center justify-center relative">
            <img src="/Achievements/medha/project-presentation-thumbnail.png" alt="Project Presentation PDF first page" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 bg-black/60 flex flex-col items-center justify-center gap-2 group-hover:bg-black/45 transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:scale-110 transition-transform duration-500"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              <span class="font-heading font-semibold text-sm text-white">Open Presentation PDF</span>
              <span class="text-[10px] text-gray-300">Opens in fullscreen new tab</span>
            </div>
          </div>
        </a>
      </div>
    </div>

    <!-- Gallery -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Gallery
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          
          <!-- Prototype -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/20">
              <img src="/Projects/PostureProBelt/medha prototype and concept.png" alt="Posture Pro Belt Prototype" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
