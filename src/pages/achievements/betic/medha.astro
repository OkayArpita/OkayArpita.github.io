                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </p>
                <p class="text-gray text-xs mt-1">Certificate for winning the Best Innovation Award at MEDHA 2024</p>
              </div>
            </a>

            <a href="/Achievements/medha/medha-2024-certi.jpg" target="_blank" class="achievement-tile group block overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
              <div class="aspect-[4/3] w-full overflow-hidden">
                <img src="/Achievements/medha/medha-2024-certi.jpg" alt="MEDHA 2024 Participation Certificate" class="w-full h-full object-contain p-2 bg-white group-hover:scale-105 transition-transform duration-700" />
              </div>
