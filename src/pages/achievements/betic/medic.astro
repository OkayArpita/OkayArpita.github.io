---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/nav.astro';

const title = "Medical Device Innovation Camp (MEDIC 2024)";
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/achievements/betic" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center">
        <img src="/BETIC.png" alt={title} class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
      <p class="text-accent font-semibold mt-2">Finalist</p>
      <div class="mt-4">
        <a href="/projects/posture-belt" class="achievement-tile inline-flex items-center gap-2 text-accent hover:text-maintext transition-colors text-sm font-semibold border border-accent/20 rounded-full px-4 py-2 hover:bg-accent/10">
          View the Posture Belt Project
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">

    <!-- About the Program -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> About the Program
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Building upon MEDHA, the <strong>Medical Device Innovation Camp (MEDIC)</strong> is BETIC's product development program where selected teams refine promising concepts into functional medical devices through design reviews, technical mentorship, and iterative prototyping.
        </p>
      </div>
    </div>

    <!-- Challenge -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Challenge
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Refine the MEDHA prototype into a practical wearable by improving its embedded electronics, mechanical design, ergonomics, power architecture, and overall product readiness.
        </p>
      </div>
    </div>

    <!-- Result & Recognition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Result & Recognition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-6">
        <ul class="list-none space-y-3">
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">✨</span> <span><strong>Developed the final 3-in-1 Posture Pro Belt</strong></span>
          </li>
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">🎤</span> <span><strong>Presented the product at the MEDIC Grand Finale at IIT Bombay</strong></span>
          </li>
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">📜</span> <span><strong>Progressed the innovation to a published Indian patent</strong></span>
          </li>
        </ul>
        <div class="border-t border-accent/10 pt-4 mt-2">
          <p class="text-accent font-semibold italic text-base md:text-lg">
            MEDIC transformed the initial proof-of-concept into a refined prototype with improved functionality, usability, and product maturity.
          </p>
        </div>
      </div>
    </div>

    <!-- Gallery -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Gallery
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          
          <!-- Weekly Reviews -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/20 border-b border-accent/10">
              <img src="/Achievements/Medic/online sessions.jpg" alt="Weekly Reviews" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-semibold text-sm">Weekly Reviews</p>
              <p class="text-gray text-xs mt-1">Design reviews and online presentation sessions with experts</p>
            </div>
          </div>

          <!-- Product Pitch -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/20 border-b border-accent/10">
              <img src="/Achievements/Medic/Pitch at IITB (1).jpg" alt="Product Pitch" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-semibold text-sm">Product Pitch</p>
              <p class="text-gray text-xs mt-1">Presenting the final product prototype to the panel</p>
            </div>
          </div>

          <!-- Technical Presentation -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/20 border-b border-accent/10">
              <img src="/Achievements/Medic/Pitch at IITB (2).jpg" alt="Technical Presentation" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-semibold text-sm">Technical Presentation</p>
              <p class="text-gray text-xs mt-1">Explaining the technical architecture and innovation</p>
            </div>
          </div>

          <!-- Expert Jury Panel -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/20 border-b border-accent/10">
              <img src="/Achievements/Medic/jury panel.JPG" alt="Expert Jury Panel" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-semibold text-sm">Expert Jury Panel</p>
              <p class="text-gray text-xs mt-1">Jury evaluating the innovation, including Prof. Shireesh B. Kedare (Director, IIT Bombay) and Prof. Parag Bhargava (Department of MEMS, IIT Bombay).</p>
            </div>
          </div>

          <!-- Grand Finale -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/20 border-b border-accent/10">
              <img src="/Achievements/Medic/Felicitation.jpg" alt="Grand Finale" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-semibold text-sm">Grand Finale</p>
              <p class="text-gray text-xs mt-1">Felicitation at the MEDIC Grand Finale at IIT Bombay</p>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Media & Featured -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Media & Featured
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-8">
        
        <!-- Official Documents -->
        <div class="space-y-4">
          <h3 class="text-lg font-heading font-bold text-maintext">Official Documents</h3>
          <div class="grid grid-cols-1 max-w-md mx-auto gap-6">
            
            <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
              <div class="aspect-[4/3] w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
                <img src="/Achievements/Medic/certificate MEDIC 2024 (Ar).jpg" alt="MEDIC Certificate" class="max-w-full max-h-full object-contain mx-auto group-hover:scale-105 transition-transform duration-700" />
              </div>
              <div class="p-4 border-t border-accent/5">
                <p class="text-maintext font-heading font-bold text-sm">Certificate of Participation</p>
                <p class="text-gray text-xs mt-1">Official certificate for the Medical Device Innovation Camp 2024</p>
              </div>
            </div>
            
          </div>
        </div>

        <!-- Press & Social Media -->
        <div class="space-y-4">
          <h3 class="text-lg font-heading font-bold text-maintext">Press & Social Media</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            
            <a href="https://www.betic.org/" target="_blank" rel="noopener noreferrer" class="achievement-tile group block overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
              <div class="aspect-video w-full overflow-hidden">
                <img src="/Achievements/Medic/betic.jpg" alt="BETIC Website" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              </div>
              <div class="p-4 border-t border-accent/5">
                <p class="text-maintext font-heading font-bold text-sm flex items-center justify-between gap-2">
                  <span>BETIC IIT Bombay Website</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </p>
                <p class="text-gray text-xs mt-1">Official portal of Biomedical Engineering and Technology Innovation Centre</p>
              </div>
            </a>

            <a href="https://www.linkedin.com/posts/okayarpita_72-hours-in-mumbai-completed-medic-2024-activity-7257217154104623104-A8dh?utm_source=social_share_send&utm_medium=member_desktop_web&rcm=ACoAAEYVexMBjaryTgP9mTSI1ewZJ0EclC9co7A" target="_blank" rel="noopener noreferrer" class="achievement-tile group block overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
              <div class="aspect-video w-full overflow-hidden">
                <img src="/Achievements/Medic/my medic linkedin post.png" alt="Personal LinkedIn Post" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              </div>
              <div class="p-4 border-t border-accent/5">
                <p class="text-maintext font-heading font-bold text-sm flex items-center justify-between gap-2">
                  <span>Personal LinkedIn Post</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </p>
                <p class="text-gray text-xs mt-1">Sharing the product presentation and experience at the MEDIC 2024 Grand Finale in IIT Bombay</p>
              </div>
            </a>

          </div>
        </div>

      </div>
    </div>

  </section>

  <!-- Project Cursor Badge -->
  <div id="project-cursor-badge" class="project-cursor-badge">
    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
      <path d="M8 5v14l11-7z" />
    </svg>
    <span>Open</span>
  </div>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }

  /* Project Cursor Badge */
  .project-cursor-badge {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    background-color: #ffffff;
    color: #000000;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
    will-change: transform, opacity;
  }
</style>

<script>
  const initCursorBadge = () => {
    const badge = document.getElementById('project-cursor-badge');
    const cards = document.querySelectorAll('.achievement-tile');
    if (!badge || cards.length === 0) return;

    let mouseX = 0;
    let mouseY = 0;
    let badgeX = 0;
    let badgeY = 0;
    let currentScale = 0.5;
    let targetScale = 0.5;
    let currentOpacity = 0;
    let targetOpacity = 0;
    let isHovering = false;

    // Track mouse coordinates globally
    const onMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    };

    window.addEventListener('mousemove', onMouseMove);

    // Mouse entering and leaving cards
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        isHovering = true;
        targetScale = 1;
        targetOpacity = 1;
      });

      card.addEventListener('mouseleave', () => {
        isHovering = false;
        targetScale = 0.5;
        targetOpacity = 0;
      });
    });

    let animationFrameId: number;

    const animate = () => {
      // Smoothen coordinates with a LERP factor (0.15)
      const dx = mouseX - badgeX;
      const dy = mouseY - badgeY;
      badgeX += dx * 0.15;
      badgeY += dy * 0.15;

      // Smoothen scale and opacity
      currentScale += (targetScale - currentScale) * 0.15;
      currentOpacity += (targetOpacity - currentOpacity) * 0.15;

      badge.style.opacity = currentOpacity.toFixed(3);
      badge.style.transform = `translate3d(${badgeX}px, ${badgeY}px, 0) translate(-50%, -50%) scale(${currentScale.toFixed(3)})`;

      animationFrameId = requestAnimationFrame(animate);
    };

    animate();

    // Return cleanup function to run on navigation/unmount
    return () => {
      window.removeEventListener('mousemove', onMouseMove);
      cancelAnimationFrame(animationFrameId);
    };
  };

  let cleanupCursor: (() => void) | null = null;

  const setupAll = () => {
    if (cleanupCursor) {
      cleanupCursor();
    }
    cleanupCursor = initCursorBadge();
  };

  window.addEventListener('load', setupAll);
  document.addEventListener('astro:after-swap', setupAll);
  setupAll();
</script>


  </section>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }
</style>
