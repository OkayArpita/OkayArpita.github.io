---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/nav.astro';

const title = "TechnoXian - World Robotics Championship";
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/#achievements" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
        <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <a href="https://www.technoxian.com/" target="_blank" rel="noopener noreferrer" class="block cursor-pointer achievement-tile">
        <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center hover:scale-105 transition-transform duration-300">
          <img src="/Technoxian.png" alt={title} class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
        </div>
        <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30 group-hover:opacity-60 transition-opacity duration-500"></div>
      </a>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
      <div class="mt-4">
        <a href="/projects/line-follower" class="achievement-tile inline-flex items-center gap-2 text-accent hover:text-maintext transition-colors text-sm font-semibold border border-accent/20 rounded-full px-4 py-2 hover:bg-accent/10">
          View the Fastest Line Follower Robot Project
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">

    <!-- Achievement Overview -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Achievement Overview
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Participated in the TechnoXian - World Robotics Championship in the Fastest Line Follower category, organized by the All India Council for Robotics & Automation (AICRA). The championship brings together students, researchers, and robotics enthusiasts from across the world to compete in advanced autonomous robotics events.
        </p>
      </div>
    </div>

    <!-- About the Competition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> About the Competition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          TechnoXian - World Robotics Championship is one of the world's largest robotics championships, attracting participants from numerous countries across multiple competition categories. The Fastest Line Follower event challenges teams to design fully autonomous robots capable of navigating complex tracks at maximum speed while maintaining precise trajectory control and stability.
        </p>
      </div>
    </div>

    <!-- The Challenge -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> The Challenge
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Design, build, and optimize a high-speed autonomous line-following robot capable of maintaining accurate path tracking under aggressive operating conditions.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Our robot was built around an STM32 microcontroller and utilized Pololu QTRX-16MD reflectance sensors, encoder-equipped micro metal gear motors, and a custom embedded control system. The software stack implemented PID-based trajectory control, yaw stabilization, and high-frequency sensor processing to achieve stable, responsive navigation at high speeds.
        </p>
      </div>
    </div>

    <!-- Result & Recognition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Result & Recognition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-6">
        <ul class="list-none space-y-3">
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">✨</span> <span>Successfully designed and developed a competition-ready autonomous line follower.</span>
          </li>
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">📈</span> <span>Validated high-speed trajectory tracking through iterative tuning and testing.</span>
          </li>
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">🧠</span> <span>Gained practical experience in embedded control systems, real-time robotics, and high-speed autonomous navigation.</span>
          </li>
        </ul>
        <div class="border-t border-accent/10 pt-4 mt-2">
          <p class="text-accent font-semibold italic text-base md:text-lg flex items-start gap-2">
            <span>🏁</span>
            <span><strong>Finals Note:</strong> During the championship, the robot underperformed due to a mismatch between the competition track dimensions and our practice arena, affecting the tuned control parameters and overall tracking performance.</span>
          </p>
        </div>
      </div>
    </div>

    <!-- Gallery -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Gallery
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          
          <!-- Robot CAD Design -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Projects/FastestLineFollowerRobot/cad-renders.jpg" alt="Robot Design" class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">Robot CAD Design</p>
              <p class="text-gray text-xs mt-1">3D CAD model rendering of the line follower robot chassis</p>
            </div>
          </div>

          <!-- Practice Arena -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Achievements/technoxian/home-made-practice-arena.jpg" alt="Practice Arena" class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">Practice Arena</p>
              <p class="text-gray text-xs mt-1">Homemade arena built for tuning and sensor response testing</p>
            </div>
          </div>

          <!-- Me at TechnoXian -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Achievements/technoxian/me-at-technoxian.jpg" alt="Me at TechnoXian" class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">Me at TechnoXian</p>
              <p class="text-gray text-xs mt-1">Representing our entry at the World Robotics Championship</p>
            </div>
          </div>

          <!-- The Venue -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
              <img src="/Achievements/technoxian/the-venue.jpg" alt="The Venue" class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">The Venue</p>
              <p class="text-gray text-xs mt-1">Official championship venue hall and setup</p>
            </div>
          </div>

          <!-- Last Minute Debugging -->
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
            <div class="aspect-video w-full overflow-hidden bg-black flex items-center justify-center relative">
              <video class="absolute w-[56.25%] h-[177.78%] object-contain -rotate-90" controls preload="metadata" playsinline>
                <source src="/Achievements/technoxian/last-minute-debugging.mp4" type="video/mp4" />
              </video>
              <!-- Fullscreen Button -->
              <button class="absolute top-2 right-2 z-20 bg-black/60 hover:bg-accent/80 text-white rounded-lg p-2 transition-colors duration-300 fullscreen-btn" title="Toggle Fullscreen">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-white"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>
              </button>
            </div>
            <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
              <p class="text-maintext font-heading font-bold text-sm">Last-Minute Debugging</p>
              <p class="text-gray text-xs mt-1">Calibrating parameters and sensor ranges on the track (rotated 90° anticlockwise)</p>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Media & Featured -->
    </svg>
    <span>Open</span>
  </div>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }

  /* Project Cursor Badge */
  .project-cursor-badge {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    background-color: #ffffff;
    color: #000000;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
    will-change: transform, opacity;
  }
</style>

<script>
  const initCursorBadge = () => { return;
    const badge = document.getElementById('project-cursor-badge');
    const cards = document.querySelectorAll('.achievement-tile');
    if (!badge || cards.length === 0) return;

    let mouseX = 0;
    let mouseY = 0;
    let badgeX = 0;
    let badgeY = 0;
    let currentScale = 0.5;
    let targetScale = 0.5;
    let currentOpacity = 0;
    let targetOpacity = 0;
    let isHovering = false;

    // Track mouse coordinates globally
    const onMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    };

    window.addEventListener('mousemove', onMouseMove);

    // Mouse entering and leaving cards
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        isHovering = true;
        targetScale = 1;
        targetOpacity = 1;
      });

      card.addEventListener('mouseleave', () => {
        isHovering = false;
        targetScale = 0.5;
        targetOpacity = 0;
      });
    });

    let animationFrameId: number;

    const animate = () => {
      // Smoothen coordinates with a LERP factor (0.15)
      badgeX = mouseX;
      badgeY = mouseY;

      // Smoothen scale and opacity
      currentScale += (targetScale - currentScale) * 0.15;
      currentOpacity += (targetOpacity - currentOpacity) * 0.15;

      badge.style.opacity = currentOpacity.toFixed(3);
      badge.style.transform = `translate3d(${badgeX}px, ${badgeY}px, 0) translate(-50%, -50%) scale(${currentScale.toFixed(3)})`;

      animationFrameId = requestAnimationFrame(animate);
    };

    animate();

    // Return cleanup function to run on navigation/unmount
    return () => {
      window.removeEventListener('mousemove', onMouseMove);
      cancelAnimationFrame(animationFrameId);
    };
  };

  const setupFullscreen = () => {
    const btns = document.querySelectorAll('.fullscreen-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const container = btn.parentElement;
        if (!container) return;
        if (!document.fullscreenElement) {
          container.requestFullscreen().catch(err => {
            console.error("Error attempting to enable fullscreen:", err);
          });
        } else {
          document.exitFullscreen();
        }
      });
    });
  };

  let cleanupCursor: (() => void) | null = null;

  const setupAll = () => {
    if (cleanupCursor) {
      cleanupCursor();
    }
    cleanupCursor = initCursorBadge();
    setupFullscreen();
  };

  window.addEventListener('load', setupAll);
  document.addEventListener('astro:after-swap', setupAll);
  setupAll();
</script>
