---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/nav.astro';

const title = "BETIC, IIT Bombay";
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/#achievements" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center">
        <img src="/BETIC.png" alt={title} class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
      <div class="mt-4">
        <a href="/projects/posture-belt" class="achievement-tile inline-flex items-center gap-2 text-accent hover:text-maintext transition-colors text-sm font-semibold border border-accent/20 rounded-full px-4 py-2 hover:bg-accent/10">
          View the Posture Belt Project
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">

    <div class="space-y-8">
      
      <!-- Edition 1 -->
      <div class="space-y-4">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
          <span class="text-accent">/</span> Medical Device Innovation Challenge (MEDIC 2024)
        </h2>
        <a href="/achievements/betic/medic" class="achievement-tile block bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4 hover:border-accent/40 transition-all duration-500 cursor-pointer">
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-accent/10 pb-4">
            <h3 class="text-xl font-heading font-bold text-accent">Finalist</h3>
            <span class="font-mono text-xs tracking-widest uppercase text-accent/75 bg-accent/10 px-3 py-1 rounded-full w-fit">October 2024</span>
          </div>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed pt-2">
            Showcased an automatic blood smear device for sickle cell anemia detection, recognized as a finalist for its impactful application in biomedical hardware.
          </p>
        </a>
      </div>

      <!-- Edition 2 -->
      <div class="space-y-4">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
          <span class="text-accent">/</span> Medical Device Hackathon (MEDHA 2024)
        </h2>
        <a href="/achievements/betic/medha" class="achievement-tile block bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4 hover:border-accent/40 transition-all duration-500 cursor-pointer">
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-accent/10 pb-4">
            <h3 class="text-xl font-heading font-bold text-accent">Best Innovation Award Winner</h3>
            <span class="font-mono text-xs tracking-widest uppercase text-accent/75 bg-accent/10 px-3 py-1 rounded-full w-fit">September 2024</span>
          </div>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed pt-2">
            Led the R&D for a portable posture correction belt prototype, focusing on the hardware-software integration. 
          </p>
        </a>
      </div>

    </div>

  </section>

  <!-- Project Cursor Badge -->
  <div id="project-cursor-badge" class="project-cursor-badge">
    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
      <path d="M8 5v14l11-7z" />
    </svg>
    <span>Open</span>
  </div>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }

  /* Project Cursor Badge */
  .project-cursor-badge {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    background-color: #ffffff;
    color: #000000;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
    will-change: transform, opacity;
  }
</style>

<script>
  const initCursorBadge = () => {
    const badge = document.getElementById('project-cursor-badge');
    const cards = document.querySelectorAll('.achievement-tile');
    if (!badge || cards.length === 0) return;

    let mouseX = 0;
    let mouseY = 0;
    let badgeX = 0;
    let badgeY = 0;
    let currentScale = 0.5;
    let targetScale = 0.5;
    let currentOpacity = 0;
    let targetOpacity = 0;
    let isHovering = false;

    // Track mouse coordinates globally
    const onMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    };

    window.addEventListener('mousemove', onMouseMove);

    // Mouse entering and leaving cards
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        isHovering = true;
        targetScale = 1;
        targetOpacity = 1;
      });

      card.addEventListener('mouseleave', () => {
        isHovering = false;
        targetScale = 0.5;
        targetOpacity = 0;
      });
    });

    let animationFrameId: number;

    const animate = () => {
      // Smoothen coordinates with a LERP factor (0.15)
      badgeX = mouseX;
      badgeY = mouseY;

      // Smoothen scale and opacity
      currentScale += (targetScale - currentScale) * 0.15;
      currentOpacity += (targetOpacity - currentOpacity) * 0.15;

      badge.style.opacity = currentOpacity.toFixed(3);
      badge.style.transform = `translate3d(${badgeX}px, ${badgeY}px, 0) translate(-50%, -50%) scale(${currentScale.toFixed(3)})`;

      animationFrameId = requestAnimationFrame(animate);
    };

    animate();

    // Return cleanup function to run on navigation/unmount
    return () => {
      window.removeEventListener('mousemove', onMouseMove);
      cancelAnimationFrame(animationFrameId);
    };
  };

  let cleanupCursor: (() => void) | null = null;

  const setupAll = () => {
    if (cleanupCursor) {
      cleanupCursor();
    }
    cleanupCursor = initCursorBadge();
  };

  window.addEventListener('load', setupAll);
  document.addEventListener('astro:after-swap', setupAll);
  setupAll();
</script>
