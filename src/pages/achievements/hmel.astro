---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/nav.astro';

const title = "HMEL Innovation Challenge";
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/#achievements" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center">
        <img src="/HMEL.png" alt={title} class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
      <p class="text-accent font-semibold mt-2">1st Runner-Up among 300+ teams</p>
      <p class="text-subtext font-mono text-xs tracking-widest uppercase mt-1">Jul 2025 - Nov 2025</p>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">

    
    <!-- Achievement -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Achievement
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Awarded National Second Prize (1st Runner-Up) in the HMEL QUEST 2025 Innovation Challenge for proposing Dynamic Floating Hydrogen Islands—an integrated offshore infrastructure concept for renewable-powered green hydrogen production. The project was recognized for its innovation, technical feasibility, and sustainability.
        </p>
      </div>
    </div>

    <!-- About HMEL -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> About HMEL
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          HPCL-Mittal Energy Limited (HMEL) is a joint venture between HPCL and Mittal Energy Investments, operating one of India's most advanced integrated refinery and petrochemical complexes in Bathinda, Punjab. The company actively drives innovation in refining, petrochemicals, renewable energy, decarbonization, and green hydrogen technologies.
        </p>
      </div>
    </div>

    <!-- About the Competition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> About the Competition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          QUEST 2025 was the third edition of HMEL's nationwide innovation challenge, inviting engineering students to solve real-world energy problems across 8 technology tracks, including Hydrogen Technology, Renewable Energy, AI & ML, Decarbonization, Nuclear Technology, and Energy Storage. Our team competed in the Hydrogen Technology track.
        </p>
      </div>
    </div>

    <!-- Competition Journey -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Competition Journey
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed mb-4">
          The competition consisted of two stages:
        </p>
        <ul class="list-disc list-outside ml-5 text-gray font-body text-base md:text-lg leading-relaxed space-y-2">
          <li><strong>Ideation Round:</strong> Submission of an original engineering proposal.</li>
          <li><strong>Final Presentation Round:</strong> Shortlisted teams presented and defended their solutions before HMEL's R&D experts through an online technical presentation.</li>
        </ul>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed mt-4">
          Our solution successfully progressed to the final stage and secured the National Second Prize.
        </p>
      </div>
    </div>

    <!-- My Contributions -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> My Contributions
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <ul class="list-disc list-outside ml-5 text-gray font-body text-base md:text-lg leading-relaxed space-y-2">
          <li>Conducted technical research and literature review</li>
          <li>Performed feasibility analysis and scientific fact verification</li>
          <li>Developed technical documentation and presentation</li>
          <li>Contributed to the overall system architecture and solution design</li>
        </ul>
      </div>
    </div>

    <!-- Winner's Experience -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Winner's Experience
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          HMEL invited all winning teams to its Guru Gobind Singh Refinery in Bathinda, Punjab, for the national felicitation ceremony. The event included interactions with Mr. Prabh Das (MD & CEO) and senior R&D leadership, a guided refinery tour, and the presentation of the cash award, certificate, and commemorative memento. Travel, accommodation, and hospitality were fully sponsored by HMEL.
        </p>
      </div>
    </div>

    <!-- Result & Recognition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Result & Recognition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <ul class="list-none space-y-3">
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">🏆</span> <span><strong>National Second Prize (1st Runner-Up)</strong></span>
          </li>
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">💰</span> <span><strong>₹1,00,000 Cash Prize</strong></span>
          </li>
          <li class="flex items-center gap-3 text-gray font-body text-base md:text-lg">
            <span class="text-xl">🏅</span> <span>Recognized for an innovative and technically feasible green hydrogen solution</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Gallery -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Gallery
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
          
          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-video w-full overflow-hidden">
              <img src="/Achievements/hmel/felicitation.png" alt="National Felicitation Ceremony" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Felicitation Ceremony</p>
              <p class="text-gray text-xs mt-1">National Felicitation Ceremony at Bathinda Refinery</p>
            </div>
          </div>

          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-video w-full overflow-hidden">
              <img src="/Achievements/hmel/team.jpg" alt="Our Team" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Our Team</p>
              <p class="text-gray text-xs mt-1">Team members representing our project</p>
            </div>
          </div>

          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-video w-full overflow-hidden">
              <img src="/Achievements/hmel/all the teams.jpg" alt="Winning Teams at HMEL" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Winning Teams</p>
              <p class="text-gray text-xs mt-1">All winning teams gathered for the ceremony</p>
            </div>
          </div>

          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-video w-full overflow-hidden">
              <img src="/Achievements/hmel/refinery tour.jpg" alt="Guided Refinery Tour" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Refinery Tour</p>
              <p class="text-gray text-xs mt-1">Guided tour of the Guru Gobind Singh Refinery</p>
            </div>
          </div>

          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-video w-full overflow-hidden">
              <img src="/Achievements/hmel/their control room.jpg" alt="Refinery Control Room" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Control Room</p>
              <p class="text-gray text-xs mt-1">Inside the highly advanced refinery control room</p>
            </div>
          </div>

          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-video w-full overflow-hidden">
              <img src="/Achievements/hmel/sponsored travel by hmel.jpg" alt="Sponsored Travel by HMEL" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Sponsored Travel</p>
              <p class="text-gray text-xs mt-1">Fully sponsored travel details by HMEL</p>
            </div>
          </div>

          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-video w-full overflow-hidden">
              <img src="/Achievements/hmel/goodies.jpg" alt="Commemorative Mementos & Goodies" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Mementos & Goodies</p>
              <p class="text-gray text-xs mt-1">Refinery mementos and certificates received</p>
            </div>
          </div>

          <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md">
            <div class="aspect-video w-full overflow-hidden">
              <img src="/Achievements/hmel/runner up list.jpg" alt="Runner Up List Announcement" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-4 border-t border-accent/5">
              <p class="text-maintext font-heading font-bold text-sm">Runner-Up List</p>
              <p class="text-gray text-xs mt-1">Official announcement showing our team position</p>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Media & Featured -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Media & Featured
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Official HMEL QUEST 2025 winner announcement, certificates, news coverage, and LinkedIn posts related to the achievement.
        </p>
      </div>
    </div>

  </section>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }
</style>
