---
import Layout from "../../layouts/Layout.astro";
import { Image } from 'astro:assets';
import { resolveAssetImage } from '../../utils/images';

const title = "Open Parametric Hand";
const profileImage = await resolveAssetImage("oph.png");
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/#projects" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background">
        {profileImage ? (
          <Image src={profileImage} alt={title} class="w-full h-full object-cover scale-110" loading="eager" />
        ) : (
          <img src="/placeholder.jpeg" alt={title} class="w-full h-full object-cover scale-110" />
        )}
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-4xl mx-auto py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">
    
    <!-- Project Summary -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="w-8 h-[2px] bg-accent"></span>
        Project Summary
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          The Voice-Controlled Open Parametric Hand (OPH) is a compact, lightweight, tendon-driven bionic hand designed to replicate the anatomical structure and movement of the human hand. Transitioning the manually operated OPH platform into a fully motorized system, this project integrates five micro metal gear motors and intelligent feedback-controlled actuation to enable advanced grasping and manipulation tasks through intuitive voice commands.
        </p>
      </div>
    </div>

    <!-- Why this Project is Important -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="w-8 h-[2px] bg-accent"></span>
        Why this Project is Important
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          This project is crucial for advancing accessible and highly functional bionic limbs. By shifting from a manually operated platform to a fully motorized, voice-controlled system, it vastly improves the ease of use and capability of prosthetics. Optimizing modular hardware architectures and creating scalable, cost-effective development workflows also ensures that this robotic hand can be rapidly prototyped and customized for diverse clinical and assistive use-cases.
        </p>
      </div>
    </div>

    <!-- Project Details -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="w-8 h-[2px] bg-accent"></span>
        Project Details
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          During my research internship under the guidance of Prof. Josie Hughes at CREATE Lab (EPFL), I focused heavily on 3D design and rapid prototyping to build this open-source robotic hand.
        </p>
        <ul class="list-disc list-outside ml-5 text-gray font-body text-base md:text-lg leading-relaxed space-y-2">
          <li>Designing and optimizing CAD models for the OPH, improving its modular prosthetic architectures.</li>
          <li>Developing parametric design strategies that incorporate anatomical tendon routing, multi-degree-of-freedom actuation, and performance tuning.</li>
          <li>Executing iterative prototyping cycles utilizing 3D printing to validate improvements, refine mechanical performance, and maintain cost-effective development workflows.</li>
          <li>Integrating five micro metal gear motors for intelligent feedback-controlled actuation, allowing the hand to perform advanced grasping through voice commands.</li>
        </ul>
      </div>
    </div>

    <!-- Technology used -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="w-8 h-[2px] bg-accent"></span>
        Technology used
      </h2>
      <div class="flex flex-wrap gap-3 pt-2">
        {["3D Printing", "CAD", "Rapid Prototyping", "Hardware Design", "Voice Control", "Micro Metal Gear Motors", "Parametric Design"].map((t) => (
          <span class="rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
            {t}
          </span>
        ))}
      </div>
    </div>

    <!-- Associated with -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="w-8 h-[2px] bg-accent"></span>
        Associated with
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 flex items-center gap-4">
        <div>
          <p class="text-maintext font-heading text-lg md:text-xl font-bold">
            CREATE Lab, EPFL
          </p>
          <p class="text-subtext font-body text-sm md:text-base mt-1">
            Research Internship | Guide: Prof. Josie Hughes<br />
            Mar '26 - May '26 (Remote)
          </p>
        </div>
      </div>
    </div>

    <!-- Certificate -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="w-8 h-[2px] bg-accent"></span>
        Certificate
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed italic">
          Letter of Recommendation / Certificate available upon request.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }
</style>
