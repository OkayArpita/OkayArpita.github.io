---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/nav.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { resolveAssetImage } from '../../utils/images';

const title = "Fastest Line Follower Robot";
const profileImage = await resolveAssetImage("line-follower@dp.jpg");
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/#projects" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center">
        {profileImage ? (
          <Image src={profileImage} alt={title} class="w-full h-full object-cover" loading="eager" />
        ) : (
          <img src="/placeholder.jpeg" alt={title} class="w-full h-full object-cover" />
        )}
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">

    <!-- Demonstrated At -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Demonstrated At
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center md:items-start gap-6">
        <div class="flex-shrink-0 bg-white w-24 h-24 rounded-xl shadow-md border border-accent/20 overflow-hidden flex items-center justify-center p-0">
          <img src="/Technoxian.png" alt="Logo" class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
        </div>
        <div class="text-center md:text-left pt-2">
          <p class="text-maintext font-heading text-xl md:text-2xl font-bold text-accent">
            Technoxian World Robotics Championship
          </p>
          <p class="text-maintext font-body text-base md:text-lg mt-2">
            All India Council for Robotics & Automation (AICRA), India
          </p>
          <p class="text-subtext font-body text-base md:text-lg mt-2 font-semibold">
            Developer / Competitor
          </p>
          <p class="text-gray font-body text-base md:text-lg mt-1">
            <span class="font-semibold text-maintext">Duration:</span> Aug 2025 to Sep 2025 (2 Months)<br/>
            <span class="font-semibold text-maintext">Project:</span> Fastest Line Follower Robot<br/>
            <span class="font-semibold text-maintext">Guides:</span> AICRA Organizers
          </p>
        </div>
      </div>
    </div>

    <!-- Project Summary -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Project Summary
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Developed an autonomous line follower for the Technoxian World Robotics Championship to navigate complex tracks at competitive speeds. The robot utilizes an STM32F103C8T6 embedded platform, infrared sensing, and encoder-based differential drive control.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          The electronic system was assembled on a lightweight double-sided prototyping PCB (dot board) instead of using 3D-printed structural components to reduce overall weight and improve the power-to-weight ratio.
        </p>
      </div>
    </div>

    <!-- Why this Project is Important -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Why this Project is Important
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          High-speed line following is a real-time embedded systems problem. Robots must execute sensing, computation, and actuation within milliseconds while maintaining stability on narrow tracks and sharp turns.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          This project involves embedded firmware development, sensor signal processing, closed-loop motion control, and lightweight hardware design. It highlights engineering trade-offs between mechanical design, power delivery, sensing accuracy, and system latency.
        </p>
      </div>
    </div>

    <!-- Project Details -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Project Details
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-10">
        
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">Real-Time Motion Control</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Designed a deterministic embedded control architecture on the STM32 platform. Implemented a PID-based trajectory tracking controller that estimates lateral position error and generates real-time steering corrections.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">High-Density Reflectance Sensing</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Integrated a Pololu QTRX-16MD infrared reflectance sensor array to detect line position. Developed sensor calibration routines for reliable measurement under varying lighting conditions.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">Embedded Hardware Architecture</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Assembled the electronic system on a prototyping PCB to minimize mass. Implemented power distribution using an MP1584 buck converter and TB6612FNG motor drivers for stable current delivery.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4">
            <img src="/Projects/FastestLineFollowerRobot/cad-render-1.jpg" alt="CAD Render" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
            <img src="/Projects/FastestLineFollowerRobot/cad-renders.jpg" alt="CAD Render 2" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
          </div>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">Precision Locomotion System</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Developed a differential-drive platform using encoder-equipped micro metal gear motors. Encoder feedback enabled accurate wheel-speed synchronization and trajectory stability.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">Embedded Firmware Development</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Wrote modular firmware in C using STM32CubeIDE, implementing peripheral drivers, PWM-based motor control, sensor acquisition routines, and closed-loop control algorithms.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">System Integration</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Iteratively tuned PID parameters, sensor calibration, and power distribution to minimize processing latency and improve dynamic response.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4">
            <img src="/Achievements/technoxian/at-technoxian.jpg" alt="At Technoxian" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
            <video controls autoplay loop muted playsinline class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/50">
              <source src="/Projects/FastestLineFollowerRobot/the-run.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>

      </div>
    </div>
    
    <!-- Engineering Challenges & Key Learnings -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Engineering Challenges & Key Learnings
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          The robot was unable to perform as expected during the championship finals due to differences between the practice environment and the official competition arena. The official arena exhibited slight differences in track width, corner geometry, and surface characteristics. Since the sensor calibration and PID controller gains had been optimized specifically for the practice track, these dimensional variations led to unstable steering corrections at competition speeds.
        </p>
        <div class="pt-2 flex justify-center">
          <img src="/Projects/FastestLineFollowerRobot/home-made-practice-arena.jpg" alt="Home Made Practice Arena" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
        </div>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed mt-4 font-bold text-maintext">
          Key Engineering Principles Highlighted:
        </p>
        <ul class="list-disc list-outside ml-5 text-gray font-body text-base md:text-lg leading-relaxed space-y-2">
          <li>Validate autonomous systems on environments that closely replicate deployment conditions.</li>
          <li>Implement adaptive sensor calibration and robust line-position estimation to accommodate geometric variations.</li>
          <li>Design control algorithms that generalize across manufacturing tolerances rather than relying solely on environment-specific parameter tuning.</li>
          <li>Incorporate systematic validation procedures before deployment in real-world environments.</li>
        </ul>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed mt-4">
          This experience reinforced that the performance of autonomous robotic systems depends heavily on the robustness of calibration, environmental adaptability, and system validation.
        </p>
      </div>
    </div>

    <!-- Tech Stack & Hardware Stack -->
    <div class="space-y-8">
      <div class="space-y-4">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
          <span class="text-accent">/</span> Tech Stack
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-2">
          <div class="flex items-center gap-3 rounded-lg p-4 bg-background border border-accent/20 text-accent transition-all shadow-sm">
            <Icon name="mdi:code-braces" class="w-8 h-8 flex-shrink-0" />
            <div>
              <p class="font-bold text-maintext">Embedded C</p>
              <p class="text-sm text-gray">Embedded firmware development</p>
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-lg p-4 bg-background border border-accent/20 text-accent transition-all shadow-sm">
            <Icon name="mdi:developer-board" class="w-8 h-8 flex-shrink-0" />
            <div>
              <p class="font-bold text-maintext">STM32CubeIDE</p>
              <p class="text-sm text-gray">Firmware development and debugging</p>
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-lg p-4 bg-background border border-accent/20 text-accent transition-all shadow-sm">
            <Icon name="mdi:cube-outline" class="w-8 h-8 flex-shrink-0" />
            <div>
              <p class="font-bold text-maintext">Autodesk Fusion</p>
              <p class="text-sm text-gray">Mechanical design and CAD</p>
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-lg p-4 bg-background border border-accent/20 text-accent transition-all shadow-sm">
            <Icon name="mdi:chart-line-variant" class="w-8 h-8 flex-shrink-0" />
            <div>
              <p class="font-bold text-maintext">PID Control</p>
              <p class="text-sm text-gray">Closed-loop trajectory tracking</p>
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-4">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
          <span class="text-accent">/</span> Hardware Stack
        </h2>
        <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 overflow-x-auto">
          <table class="w-full text-left text-sm md:text-base font-body border-collapse">
            <thead>
              <tr class="border-b border-accent/20">
                <th class="py-3 px-4 text-accent font-bold">Component</th>
                <th class="py-3 px-4 text-accent font-bold">Purpose</th>
              </tr>
            </thead>
            <tbody class="text-gray divide-y divide-accent/10">
              <tr>
                <td class="py-3 px-4 font-semibold text-maintext">STM32F103C8T6 (Blue Pill)</td>
                <td class="py-3 px-4 leading-relaxed">Main real-time embedded controller</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-semibold text-maintext">Pololu QTRX-16MD</td>
                <td class="py-3 px-4 leading-relaxed">16-channel infrared reflectance sensor array for line detection</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-semibold text-maintext">CD74HC4067</td>
                <td class="py-3 px-4 leading-relaxed">16-channel analog multiplexer for sensor signal routing</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-semibold text-maintext">TB6612FNG ×2</td>
                <td class="py-3 px-4 leading-relaxed">Independent H-bridge motor drivers for stable current delivery</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-semibold text-maintext">Micro Metal Gear Motors</td>
                <td class="py-3 px-4 leading-relaxed">Differential-drive locomotion with magnetic encoder feedback</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-semibold text-maintext">MP1584 Buck Converter</td>
                <td class="py-3 px-4 leading-relaxed">High-efficiency DC-DC voltage regulation</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-semibold text-maintext">11.1 V 360 mAh 30C 3S Li-Po</td>
                <td class="py-3 px-4 leading-relaxed">High-current power source for motors and control electronics</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-semibold text-maintext">Double-Sided Dot Board</td>
                <td class="py-3 px-4 leading-relaxed">Lightweight custom electronics integration platform</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- Certificate -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Certificate
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 flex justify-center">
        <img src="/Projects/FastestLineFollowerRobot/Participation%20Certificate.jpg" alt="Participation Certificate" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
      </div>
    </div>

  </section>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }
</style>


