---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/nav.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { resolveAssetImage } from '../../utils/images';

const title = "Fast Line Follower Robot";
const profileImage = await resolveAssetImage("line-follower@dp.png");
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/#projects" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center">
        {profileImage ? (
          <Image src={profileImage} alt={title} class="w-full h-full object-cover" loading="eager" />
        ) : (
          <img src="/placeholder.jpeg" alt={title} class="w-full h-full object-cover" />
        )}
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
      <br>
      <p class="text-gray font-body text-lg leading-relaxed">
        High-Speed Autonomous Line Following Robot for Competitive Robotics
      </p>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">

    <!-- Demonstrated At -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Demonstrated At
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center md:items-start gap-6">
        <div class="flex-shrink-0 bg-white w-24 h-24 rounded-xl shadow-md border border-accent/20 overflow-hidden flex items-center justify-center p-0">
          <img src="/Technoxian.png" alt="Logo" class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
        </div>
        <div class="text-center md:text-left pt-2">
          <p class="text-maintext font-heading text-xl md:text-2xl font-bold text-accent">
            Technoxian World Robotics Championship
          </p>
          <p class="text-maintext font-body text-base md:text-lg mt-2">
            All India Council for Robotics & Automation (AICRA)
          </p>
          <p class="text-subtext font-body text-base md:text-lg mt-2 font-semibold">
            Role: Developer
          </p>
          <p class="text-subtext font-body text-base md:text-lg mt-2 font-semibold">
            Duration: Aug 2025 – Sep 2025
          </p>
        </div>
      </div>
    </div>

    <!-- Project Summary -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Project Summary
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Designed and developed a high-speed autonomous line follower for the Technoxian World Robotics Championship, engineered to navigate complex tracks featuring sharp corners, hairpin bends, and a 2 cm track width at competitive speeds. The robot was built around an STM32F103C8T6 real-time embedded platform, integrating high-density infrared sensing, encoder-based differential drive control, and low-latency motor actuation.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          To maximize performance, the complete electronic system was assembled on a lightweight double-sided prototyping PCB (dot board) without using any 3D-printed structural components, significantly reducing overall weight while improving structural rigidity, ease of maintenance, and overall power-to-weight ratio for competitive racing.
        </p>
      </div>
    </div>

    <!-- Why this Project is Important -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Why this Project is Important
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          High-speed line following is fundamentally a real-time embedded systems and control engineering problem. Unlike conventional educational line followers, competitive robots must execute sensing, computation, and actuation within milliseconds while maintaining stability at high velocities through sharp turns and narrow tracks.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          This project demonstrates expertise in embedded firmware development, sensor signal processing, closed-loop motion control, lightweight hardware design, and autonomous navigation. It also highlights the engineering trade-offs between mechanical design, power delivery, sensing accuracy, controller tuning, and system latency required to build reliable high-performance autonomous robots.
        </p>
      </div>
    </div>

    <!-- Project Details -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Project Details
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-10">
        
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">Real-Time Motion Control</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Designed a deterministic embedded control architecture on the STM32 platform for high-speed differential-drive navigation. Implemented a PID-based trajectory tracking controller that continuously estimates lateral position error from the reflectance sensor array and generates real-time steering corrections while maintaining forward velocity through high-curvature sections of the track.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">High-Density Reflectance Sensing</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Integrated a Pololu QTRX-16MD high-density infrared reflectance sensor array to accurately detect and estimate line position on narrow 2 cm competition tracks. Developed sensor calibration and signal-processing routines for reliable reflectance measurement, enabling robust line detection under varying surface reflectivity and ambient lighting conditions.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">Embedded Hardware Architecture</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Designed and assembled the complete electronic system on a lightweight double-sided prototyping PCB (dot board), eliminating the need for 3D-printed structural components to minimize overall mass. Implemented an efficient power distribution architecture using an MP1584 buck converter for voltage regulation and dedicated TB6612FNG motor drivers for each drive motor, ensuring stable current delivery and rapid motor response during aggressive acceleration.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <img src="/Projects/FastestLineFollowerRobot/CAD%20render.png" alt="CAD Render" class="rounded-lg border border-accent/20 shadow-md w-full aspect-video object-cover" />
            <img src="/Projects/FastestLineFollowerRobot/Cad%20renders.png" alt="CAD Render 2" class="rounded-lg border border-accent/20 shadow-md w-full aspect-video object-cover" />
          </div>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">Precision Locomotion System</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Developed a differential-drive locomotion platform using encoder-equipped micro metal gear motors to achieve responsive steering and smooth velocity control. The encoder feedback enabled accurate wheel-speed synchronization, improving trajectory stability while negotiating sharp turns and maintaining high-speed performance.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">Embedded Firmware Development</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Developed modular firmware in Embedded C using STM32CubeIDE, implementing peripheral drivers, PWM-based motor control, sensor acquisition routines, encoder interfacing, and closed-loop control algorithms. The software architecture was organized into independent hardware abstraction, sensing, control, and actuation layers to simplify debugging, controller tuning, and future hardware upgrades.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">System Integration & Performance Optimization</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Optimized the complete sensing-to-actuation pipeline through iterative tuning of PID parameters, sensor calibration, power distribution, and mechanical layout. Particular emphasis was placed on minimizing processing latency, reducing electrical noise, lowering overall system weight, and improving dynamic response to achieve consistent high-speed tracking on complex competition tracks.
          </p>
          <img src="/Projects/FastestLineFollowerRobot/at%20technoxian.png" alt="At Technoxian" class="rounded-lg border border-accent/20 shadow-md w-full max-w-3xl mx-auto object-cover" />
        </div>

      </div>
    </div>
    
    <!-- Engineering Challenges & Key Learnings -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Engineering Challenges & Key Learnings
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Although the robot demonstrated reliable high-speed performance during development and extensive internal testing, it was unable to perform as expected during the championship finals due to differences between the practice environment and the official competition arena.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          The robot had been developed and tuned using a self-fabricated practice track constructed indoors. During the finals, the official competition arena exhibited slight differences in track width, corner geometry, and surface characteristics. Since the reflectance sensor calibration and PID controller gains had been optimized specifically for the practice track, these dimensional variations altered the measured line position and tracking error, leading to unstable steering corrections at competition speeds.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed mt-4 font-bold text-maintext">
          This experience highlighted several important engineering principles:
        </p>
        <ul class="list-disc list-outside ml-5 text-gray font-body text-base md:text-lg leading-relaxed space-y-2">
          <li>The necessity of validating autonomous systems on environments that closely replicate deployment conditions.</li>
          <li>The importance of adaptive sensor calibration and robust line-position estimation to accommodate geometric and environmental variations.</li>
          <li>Designing control algorithms that generalize across manufacturing tolerances rather than relying solely on environment-specific parameter tuning.</li>
          <li>Incorporating systematic validation procedures and parameter verification before deployment in competitive or real-world environments.</li>
        </ul>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed mt-4">
          The project reinforced that the performance of autonomous robotic systems depends not only on hardware capability and control algorithms but also on the robustness of calibration, environmental adaptability, and system validation. These insights have significantly influenced my subsequent approach to embedded robotics by prioritizing repeatability, portability, and resilience during system design.
        </p>
      </div>
    </div>

    <!-- Tech Stack -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Tech Stack
      </h2>
      <div class="flex flex-wrap gap-4 pt-2">
        <div class="flex items-center gap-2 rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
          <Icon name="mdi:code-braces" class="w-5 h-5" />
          Embedded C
        </div>
        <div class="flex items-center gap-2 rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
          <Icon name="mdi:developer-board" class="w-5 h-5" />
          STM32CubeIDE
        </div>
        <div class="flex items-center gap-2 rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
          <Icon name="mdi:cube-outline" class="w-5 h-5" />
          Autodesk Fusion
        </div>
        <div class="flex items-center gap-2 rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
          <Icon name="mdi:chart-line-variant" class="w-5 h-5" />
          PID Control
        </div>
      </div>
    </div>

    <!-- Hardware Stack -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Hardware Stack
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 overflow-x-auto">
        <table class="w-full text-left text-sm md:text-base font-body border-collapse">
          <thead>
            <tr class="border-b border-accent/20">
              <th class="py-3 px-4 text-accent font-bold">Component</th>
              <th class="py-3 px-4 text-accent font-bold">Purpose</th>
            </tr>
          </thead>
          <tbody class="text-gray divide-y divide-accent/10">
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">STM32F103C8T6 (Blue Pill)</td>
              <td class="py-3 px-4 leading-relaxed">Main real-time embedded controller</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">Pololu QTRX-16MD</td>
              <td class="py-3 px-4 leading-relaxed">16-channel infrared reflectance sensor array for line detection</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">CD74HC4067</td>
              <td class="py-3 px-4 leading-relaxed">16-channel analog multiplexer for sensor signal routing</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">TB6612FNG ×2</td>
              <td class="py-3 px-4 leading-relaxed">Independent H-bridge motor drivers (one per motor) for higher current delivery</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">Micro Metal Gear Motors</td>
              <td class="py-3 px-4 leading-relaxed">Differential-drive locomotion with magnetic encoder feedback</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">MP1584 Buck Converter</td>
              <td class="py-3 px-4 leading-relaxed">High-efficiency DC-DC voltage regulation</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">11.1 V 360 mAh 30C 3S Li-Po</td>
              <td class="py-3 px-4 leading-relaxed">High-current power source for motors and control electronics</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">Double-Sided Dot Board</td>
              <td class="py-3 px-4 leading-relaxed">Lightweight custom electronics integration platform</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Core Engineering Concepts -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Core Engineering Concepts
      </h2>
      <div class="flex flex-wrap gap-3 pt-2">
        {[
          "Real-Time Embedded Systems", "Autonomous Mobile Robotics", "Differential Drive Kinematics",
          "Closed-Loop Motion Control", "PID Controller Design & Tuning", "Reflectance Sensor Signal Processing",
          "PWM Motor Control", "Encoder-Based Feedback Control", "Embedded Firmware Development",
          "Low-Latency Control Systems", "High-Speed Autonomous Navigation", "Lightweight Embedded Hardware Design",
          "Power Electronics for Mobile Robots", "Competition Robotics Engineering"
        ].map((concept) => (
          <span class="rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
            {concept}
          </span>
        ))}
      </div>
    </div>

  </section>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }
</style>
