---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/nav.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { resolveAssetImage } from '../../utils/images';

const title = "Maze Solver Bot";
const profileImage = await resolveAssetImage("maze-solver@dp.jpg");
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/#projects" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center">
        {profileImage ? (
          <Image src={profileImage} alt={title} class="w-full h-full object-cover" loading="eager" />
        ) : (
          <img src="/placeholder.jpeg" alt={title} class="w-full h-full object-cover" />
        )}
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">

    <!-- Demonstrated At -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Demonstrated At
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center md:items-start gap-6">
        <div class="flex-shrink-0 bg-white w-24 h-24 rounded-xl shadow-md border border-accent/20 overflow-hidden flex items-center justify-center p-0">
          <img src="/eYantra.png" alt="Logo" class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
        </div>
        <div class="text-center md:text-left pt-2">
          <p class="text-maintext font-heading text-xl md:text-2xl font-bold text-accent">
            e-Yantra Robotics Competition (eYRC 2025-26)
          </p>
          <p class="text-maintext font-body text-base md:text-lg mt-2">
            Department of Computer Science & Engineering, IIT Bombay, India
          </p>
          <p class="text-subtext font-body text-base md:text-lg mt-2 font-semibold">
            FPGA & Embedded Systems Developer
          </p>
          <p class="text-gray font-body text-base md:text-lg mt-1">
            <span class="font-semibold text-maintext">Duration:</span> Aug 2025 to Mar 2026 (8 Months)<br/>
            <span class="font-semibold text-maintext">Project:</span> Maze Solver Bot<br/>
            <span class="font-semibold text-maintext">Guides:</span> e-Yantra Lab Mentors
          </p>
        </div>
      </div>
    </div>

    <!-- Project Summary -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Project Summary
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Developed an FPGA-based autonomous robot for the e-Yantra Robotics Competition (eYRC 2025-26) designed to navigate dynamic warehouse environments and perform post-harvest monitoring. Implemented the complete control pipeline in Verilog HDL on an Intel DE0-Nano FPGA to execute navigation, motor control, sensing, and wireless telemetry concurrently.
        </p>
      </div>
    </div>

    <!-- About the Competition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> About the Competition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          The e-Yantra Robotics Competition (eYRC) is hosted by IIT Bombay to challenge participants to build complete physical robots integrating digital hardware, embedded electronics, mechanical design, and control systems.
        </p>
        <ul class="list-disc list-outside ml-5 text-gray font-body text-base md:text-lg leading-relaxed space-y-2">
          <li><strong>Stage 1 (Simulation Phase):</strong> Develop and validate autonomous navigation algorithms in simulation.</li>
          <li><strong>Stage 2 (Hardware Phase):</strong> Build the physical robot from scratch, including PCB routing, chassis fabrication, Verilog controller development, and sensor calibration. Our team completed this stage and earned Level-2 Certification.</li>
          <li><strong>Stage 3 (National Finals):</strong> Final evaluation of the integrated robot at IIT Bombay.</li>
        </ul>
      </div>
    </div>

    <!-- Why this Project is Important -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Why this Project is Important
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          High-speed autonomous navigation demands deterministic, low-latency processing. Executing sensing, control, and communication concurrently on programmable logic (FPGA) avoids the sequential execution bottlenecks of conventional microcontrollers.
        </p>
      </div>
    </div>

    <!-- Project Details -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Project Details
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-10">
        
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">FPGA Control Architecture</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Designed a modular digital architecture on the Intel DE0-Nano FPGA using Verilog HDL. A custom CPU architecture coordinates parallel hardware modules for ultrasonic ranging, infrared detection, encoder feedback, PWM generation, and UART telemetry.
          </p>
          <div class="pt-2 flex justify-center">
            <img src="/Projects/MazeSolverBot/quartus-simulation.jpg" alt="Quartus Simulation" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
          </div>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">Autonomous Maze Navigation</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Implemented a wall-following and maze-exploration algorithm on the FPGA. The robot uses ultrasonic sensors to detect walls, processes path updates, and synchronizes coordinates with the Central Control Unit.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">Environmental Monitoring System</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Designed a servo-actuated mechanical arm carrying a capacitive soil moisture sensor. The arm aligns the sensor at checkpoints detected by infrared sensors to capture agricultural telemetry.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">Electronic System Design</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Designed a custom PCB in KiCad for power distribution, voltage regulation, FPGA I/O breakout, and motor driver isolation to ensure electrical reliability.
          </p>
          <div class="pt-2 flex justify-center">
            <img src="/Projects/MazeSolverBot/custom-pcb.jpg" alt="Custom PCB design" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
          </div>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">Mechanical Design & Fabrication</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Modeled the chassis, sensor mounts, and servo mechanisms in Autodesk Fusion. Optimized structural components for weight distribution and fabricated them using 3D printing.
          </p>
          <div class="pt-2 flex justify-center">
            <img src="/Projects/MazeSolverBot/cad-design.png" alt="CAD design" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
          </div>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">System Integration & Validation</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Assembled and validated the electromechanical subsystems, control logic, and wireless communication, testing navigation reliability under competition arena constraints.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4">
            <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
              <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
                <img src="/Projects/MazeSolverBot/arena-making.jpg" alt="Arena Fabrication" class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-700" />
              </div>
              <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
                <p class="text-maintext font-heading font-bold text-sm">Arena Fabrication</p>
                <p class="text-gray text-xs mt-1">Fabricating the testing arena.</p>
              </div>
            </div>
            <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
              <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
                <video controls autoplay loop muted playsinline class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-700">
                  <source src="/Projects/MazeSolverBot/hardware-demo.mp4" type="video/mp4" />
                  Your browser does not support the video tag.
                </video>
              </div>
              <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
                <p class="text-maintext font-heading font-bold text-sm">Hardware Demo</p>
                <p class="text-gray text-xs mt-1">System in action.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Results & Contributions -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Results & Contributions
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <ul class="list-disc list-outside ml-5 text-gray font-body text-base md:text-lg leading-relaxed space-y-2">
          <li>Designed an FPGA-based autonomous robotic platform using Verilog HDL</li>
          <li>Developed a custom CPU architecture for concurrent hardware task scheduling</li>
          <li>Implemented autonomous maze-solving logic for dynamic warehouse navigation</li>
          <li>Designed PWM-based motor control and encoder interfacing modules</li>
          <li>Integrated ultrasonic, infrared, and soil moisture sensing systems</li>
          <li>Developed UART-based wireless communication with the Central Control Unit (CCU)</li>
          <li>Designed and routed a custom PCB for power management and peripheral integration</li>
          <li>Engineered a servo-actuated environmental sensing mechanism</li>
          <li>Designed and fabricated a custom 3D-printed robotic chassis</li>
          <li>Performed complete electromechanical system integration, validation, and testing</li>
        </ul>
      </div>
    </div>

    <!-- Results & Contributions -->
    <div class="space-y-4">

      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Qualified for the Hardware Development Stage (Level-2 Certification) of the e-Yantra Robotics Competition (eYRC 2025-26) by completing the simulation phase. Designed, fabricated, and validated a complete FPGA-controlled robot within official competition rules.
        </p>
      </div>
    </div>

    <!-- Tech Stack -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Tech Stack
      </h2>
      <div class="flex flex-wrap gap-4 pt-2">
        <div class="flex items-center gap-2 rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
          <Icon name="mdi:code-braces" class="w-5 h-5" />
          Verilog HDL
        </div>
        <div class="flex items-center gap-2 rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
          <Icon name="mdi:developer-board" class="w-5 h-5" />
          Intel Quartus Prime
        </div>
        <div class="flex items-center gap-2 rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
          <Icon name="mdi:language-cpp" class="w-5 h-5" />
          C
        </div>
        <div class="flex items-center gap-2 rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
          <Icon name="mdi:layers-outline" class="w-5 h-5" />
          KiCad
        </div>
        <div class="flex items-center gap-2 rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
          <Icon name="mdi:cube-outline" class="w-5 h-5" />
          Autodesk Fusion
        </div>
      </div>
    </div>

    <!-- Hardware Stack -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Hardware Stack
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 overflow-x-auto">
        <table class="w-full text-left text-sm md:text-base font-body border-collapse">
          <thead>
            <tr class="border-b border-accent/20">
              <th class="py-3 px-4 text-accent font-bold">Component</th>
              <th class="py-3 px-4 text-accent font-bold">Purpose</th>
            </tr>
          </thead>
          <tbody class="text-gray divide-y divide-accent/10">
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">Intel DE0-Nano FPGA Board</td>
              <td class="py-3 px-4 leading-relaxed">Primary processing platform implementing custom CPU architecture, navigation logic, motor control, sensing, and communication in programmable logic</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">Custom PCB</td>
              <td class="py-3 px-4 leading-relaxed">Integrated power management, voltage regulation, FPGA interfaces, signal routing, and peripheral connectivity</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">HC-SR04 Ultrasonic Sensor</td>
              <td class="py-3 px-4 leading-relaxed">Wall detection, obstacle localization, and real-time distance measurement for autonomous navigation</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">Digital IR Sensor</td>
              <td class="py-3 px-4 leading-relaxed">Detection of designated environmental sensing checkpoints within the warehouse</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">Capacitive Soil Moisture Sensor</td>
              <td class="py-3 px-4 leading-relaxed">Acquisition of soil moisture measurements at specified monitoring locations</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">600 RPM N20 Geared Motors with Encoders</td>
              <td class="py-3 px-4 leading-relaxed">Differential-drive locomotion with encoder feedback for precise movement control</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">TB6612FNG Dual Motor Driver</td>
              <td class="py-3 px-4 leading-relaxed">Bidirectional motor actuation driven through FPGA-generated PWM signals</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">MG90S Servo Motor</td>
              <td class="py-3 px-4 leading-relaxed">Actuated the soil moisture sensing arm for automated environmental sampling</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">HC-05 Bluetooth Module</td>
              <td class="py-3 px-4 leading-relaxed">UART-based wireless communication with the Central Control Unit for telemetry and blocked-path reporting</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-semibold text-maintext">3D Printed Robot Chassis</td>
              <td class="py-3 px-4 leading-relaxed">Lightweight structural platform supporting the FPGA board, sensing modules, drivetrain, and custom electronics</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Certificates & Recognition -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Certificates & Recognition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
          <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
            <img src="/Projects/MazeSolverBot/certificate-page-1.jpg" alt="eYRC Certificate Page 1" class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
            <p class="text-maintext font-heading font-bold text-sm">Certificate Page 1</p>
            <p class="text-gray text-xs mt-1">eYRC Level-2 Certification.</p>
          </div>
        </div>
        <div class="group relative overflow-hidden rounded-xl border border-accent/10 hover:border-accent/40 transition-all duration-500 bg-background/50 shadow-md flex flex-col">
          <div class="aspect-video w-full overflow-hidden bg-black/10 flex items-center justify-center p-2">
            <img src="/Projects/MazeSolverBot/certificate-page-2.jpg" alt="eYRC Certificate Page 2" class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="p-4 border-t border-accent/5 flex-grow flex flex-col justify-center">
            <p class="text-maintext font-heading font-bold text-sm">Certificate Page 2</p>
            <p class="text-gray text-xs mt-1">eYRC Level-2 Certification details.</p>
          </div>
        </div>
      </div>
    </div>

  </section>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }
</style>


