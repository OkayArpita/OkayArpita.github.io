---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/nav.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { resolveAssetImage } from '../../utils/images';

const title = "Dental Intraoral Scanner";
const profileImage = await resolveAssetImage("scanner@dp.png");
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/#projects" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center">
        {profileImage ? (
          <Image src={profileImage} alt={title} class="w-full h-full object-cover" loading="eager" />
        ) : (
          <img src="/placeholder.jpeg" alt={title} class="w-full h-full object-cover" />
        )}
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">
    
    <!-- Demonstrated At -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Demonstrated At
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center md:items-start gap-6">
        <div class="flex-shrink-0 bg-white w-24 h-24 rounded-xl shadow-md border border-accent/20 overflow-hidden flex items-center justify-center p-0">
          <img src="/IIT_Bombay.png" alt="Logo" class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
        </div>
        <div class="text-center md:text-left pt-2">
          <p class="text-maintext font-heading text-xl md:text-2xl font-bold text-accent">
            Biomedical Engineering and Technology Innovation Centre (BETIC)
          </p>
          <p class="text-maintext font-body text-base md:text-lg mt-2">
            IIT Bombay, India
          </p>
          <p class="text-subtext font-body text-base md:text-lg mt-2 font-semibold">
            Summer Research Internship <span class="text-yellow-500">(Full Time - On Site)</span>
          </p>
          <p class="text-gray font-body text-base md:text-lg mt-1">
            <span class="font-semibold text-maintext">Project:</span> Helios 500 Intraoral Scanner Analysis<br/>
            <span class="font-semibold text-maintext">Guides:</span> Prof. Parag Bhargava and Dr. Bhanupratap Gaur
          </p>
          <p class="text-subtext font-body text-base md:text-lg mt-2 font-semibold">
            19 May - 11 July 2025
          </p>
        </div>
      </div>
    </div>

    <!-- Project Summary -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Project Summary
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          During my eight-week internship at the <strong>Biomedical Engineering and Technology Innovation Centre (BETIC), IIT Bombay</strong>, I worked as an Electronics Engineering Intern on medical device innovation projects supported by the <strong>Indian Council of Medical Research (ICMR)</strong>.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Among the ongoing projects in the laboratory, I was particularly involved with the development of an <strong>indigenous dental intraoral scanner</strong>. As part of the research and development process, BETIC procured the <strong>Helios 500</strong> commercial intraoral scanner as a <strong>predicate device</strong> for technical evaluation and benchmarking.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          My work focused on understanding the scanner's complete operational workflow, evaluating its scanning performance under different experimental conditions, analysing its software ecosystem and post-processing capabilities, documenting operational limitations, and generating technical insights to support the development of an indigenous intraoral scanning system.
        </p>
      </div>
    </div>

    <!-- Why this Project is Important -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Why this Project is Important
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Intraoral scanners digitally capture the three-dimensional geometry of the oral cavity, replacing conventional physical impressions used in restorative and orthodontic dentistry. These digital models enable faster and more accurate workflows for the design and manufacturing of:
        </p>
        <ul class="list-disc list-inside text-gray font-body text-base md:text-lg space-y-2 pl-4">
          <li>Dental crowns and bridges</li>
          <li>Dentures</li>
          <li>Orthodontic aligners and braces</li>
          <li>Implant planning</li>
          <li>Digital dental records</li>
        </ul>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed mt-2">
          Beyond dentistry, the underlying optical scanning and 3D reconstruction technologies are applicable to reverse engineering, prosthetics, biomedical modelling, and high-precision surface digitisation. To develop an indigenous intraoral scanner, it is essential to understand how existing commercial systems perform under practical operating conditions, identify their strengths and limitations, and evaluate the complete user workflow from image acquisition to final 3D model generation.
        </p>
      </div>
    </div>

    <!-- Engineering Context -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Engineering Context
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Prior to acquiring the commercial scanner, the research team was actively developing an indigenous intraoral scanning system by experimenting with custom camera and optical projection setups. The work involved grayscale image acquisition, image stitching, and preliminary 3D reconstruction studies.
        </p>
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          To accelerate product development and establish a performance benchmark, the <strong>Helios 500</strong> was procured as a commercial reference device. My role involved conducting a structured technical evaluation of the scanner through practical experimentation, software exploration, and workflow analysis to understand its capabilities and identify observations relevant to future system development.
        </p>
      </div>
    </div>

    <!-- Project Details -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Project Details
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-12">
        
        <!-- Module 1 -->
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">1. Device Familiarisation &amp; Workflow Analysis</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            The first phase involved understanding the complete operational workflow of the Helios 500. This included device setup and calibration, scan initiation, real-time visualization of reconstructed geometry, scan completion, and exporting reconstructed digital models.
          </p>
          <div class="flex justify-center mt-4">
            <video controls autoplay loop muted playsinline class="rounded-lg border border-accent/20 shadow-md w-full max-w-2xl aspect-video object-cover bg-black/50">
              <source src="/Projects/DentalIntraoralScanner/scanning.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>

        <hr class="border-accent/10" />

        <!-- Module 2 -->
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">2. Comparative Dental Scanning &amp; 3D Reconstruction</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Multiple scanning experiments were performed using two different dental cast models available in the laboratory, which differed in tooth morphology, surface texture, and anatomical features. Each experiment involved acquiring overlapping scan frames while observing the real-time generation of the digital model. The reconstructed outputs were assessed for acquisition continuity, registration quality, surface completeness, and geometric fidelity.
          </p>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            To investigate tracking capability, both dental cast models were scanned simultaneously within a single acquisition session. This experiment evaluated the scanner's ability to distinguish and reconstruct multiple independent dental geometries while maintaining registration accuracy.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
            <div class="space-y-2">
              <img src="/Projects/DentalIntraoralScanner/lower teeth full scan.jpg" alt="Lower Teeth Full Scan" class="rounded-lg border border-accent/20 shadow-md w-full object-cover aspect-[4/3] bg-white/5" />
              <p class="text-xs text-subtext text-center italic">Reconstructed 3D geometry of full lower teeth dental model</p>
            </div>
            <div class="space-y-2">
              <img src="/Projects/DentalIntraoralScanner/two different dentures in one scan.jpg" alt="Two Dentures In One Scan" class="rounded-lg border border-accent/20 shadow-md w-full object-cover aspect-[4/3] bg-white/5" />
              <p class="text-xs text-subtext text-center italic">Simultaneous scanning and registration of two independent dental cast models</p>
            </div>
          </div>
        </div>

        <hr class="border-accent/10" />

        <!-- Module 3 -->
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">3. Non-Dental Object Evaluation</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            To study the scanner's behaviour beyond its intended application, additional experiments were conducted using a keyring as a non-dental object. Unlike the dental models, the scanner struggled to generate a complete and geometrically accurate reconstruction. This comparative evaluation highlighted the high degree of optimization of commercial intraoral scanners for dental anatomy, showing limitations of the reconstruction pipeline when applied to arbitrary geometries lacking dental-specific landmarks.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
            <div class="space-y-2">
              <img src="/Projects/DentalIntraoralScanner/keyring.jpg" alt="Physical Keyring" class="rounded-lg border border-accent/20 shadow-md w-full object-cover aspect-[4/3] bg-white/5" />
              <p class="text-xs text-subtext text-center italic">Physical keyring object used for non-dental testing</p>
            </div>
            <div class="space-y-2">
              <img src="/Projects/DentalIntraoralScanner/keyringscan.jpg" alt="Keyring 3D Reconstruction Attempt" class="rounded-lg border border-accent/20 shadow-md w-full object-cover aspect-[4/3] bg-white/5" />
              <p class="text-xs text-subtext text-center italic">Failed/noisy reconstruction attempt highlighting software pipeline assumptions</p>
            </div>
          </div>
        </div>

        <hr class="border-accent/10" />

        <!-- Module 4 -->
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">4. Software &amp; Post-Processing Evaluation</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            A detailed exploration of the Helios 500 software ecosystem was carried out to understand its post-processing capabilities, including real-time scan visualisation, region selection and trimming, removal of unwanted scan areas, AI-assisted reconstruction of missing regions, surface refinement, and final model export (STL/OBJ).
          </p>
          <div class="flex justify-center mt-4">
            <video controls autoplay loop muted playsinline class="rounded-lg border border-accent/20 shadow-md w-full max-w-2xl aspect-video object-cover bg-black/50">
              <source src="/Projects/DentalIntraoralScanner/scanned.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>

        <hr class="border-accent/10" />

        <!-- Module 5 -->
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">5. Performance Observation &amp; Failure Analysis</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Repeated scanning sessions enabled the identification of practical limitations in the scanner's operation. One recurring observation was the occasional freezing of the acquisition process during active scanning. Although the software recovered after a short interruption, the reconstruction pipeline did not consistently resume from the exact point where acquisition had stopped, leading to lost scan sequences and requiring the operator to revisit previously scanned regions.
          </p>
          <div class="space-y-2 max-w-2xl mx-auto">
            <img src="/Projects/DentalIntraoralScanner/overlapping flaws.jpg" alt="Overlapping Flaws" class="rounded-lg border border-accent/20 shadow-md w-full object-cover bg-white/5" />
            <p class="text-xs text-subtext text-center italic">Registration flaws and reconstruction overlap errors during tracking disruptions</p>
          </div>
        </div>

        <hr class="border-accent/10" />

        <!-- Module 6 -->
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">6. Technical Documentation &amp; Presentation</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Throughout the internship, all findings, comparative experimental runs, software capabilities, and performance observations were systematically documented. The resulting technical documentation and engineering presentations were delivered to the research team at BETIC, providing baseline insights for their indigenous intraoral scanner R&D efforts.
          </p>
        </div>

      </div>
    </div>

    <!-- Tech Stack -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Tech Stack
      </h2>
      <div class="flex flex-wrap gap-4 pt-2">
        {[
          { name: "Intraoral Optical Scanning", icon: "mdi:camera" },
          { name: "3D Surface Reconstruction", icon: "mdi:rotate-3d-variant" },
          { name: "Predicate Device Benchmarking", icon: "mdi:chart-bar" },
          { name: "Comparative Performance Analysis", icon: "mdi:scale-balance" },
          { name: "CAD Model Generation", icon: "mdi:cube-outline" },
          { name: "Image Registration", icon: "mdi:vector-combine" },
          { name: "AI-assisted Post-processing", icon: "mdi:robot" },
          { name: "Functional & Failure-mode Testing", icon: "mdi:alert-circle-outline" },
          { name: "Technical Reporting", icon: "mdi:file-document-outline" }
        ].map((t) => (
          <div class="flex items-center gap-2 rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
            <Icon name={t.icon} class="w-5 h-5" />
            {t.name}
          </div>
        ))}
      </div>
    </div>

  </section>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }
</style>
