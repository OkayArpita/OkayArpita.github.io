---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/nav.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { resolveAssetImage } from '../../utils/images';

const title = "Dental Intraoral Scanner";
const profileImage = await resolveAssetImage("scanner@dp.png");
---
<Layout title={title}>
  <!-- Back Button -->
  <div class="fixed top-4 left-4 z-50 reveal-content" style="animation-delay: 700ms;">
    <a href="/#projects" class="group flex items-center justify-center w-12 h-12 bg-background/50 backdrop-blur-md rounded-full border border-accent/10 hover:border-accent/50 hover:bg-accent/10 transition-all duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:text-maintext transition-colors"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <Nav />
  
  <section class="flex flex-col items-center justify-center section-container pt-20 md:pt-30 gap-1 min-h-[50vh] text-center">
    <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)] bg-background flex items-center justify-center">
        {profileImage ? (
          <Image src={profileImage} alt={title} class="w-full h-full object-cover" loading="eager" />
        ) : (
          <img src="/placeholder.jpeg" alt={title} class="w-full h-full object-cover" />
        )}
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-30"></div>
    </div>
    
    <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
      <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight mt-6">
        {title}
      </h1>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="px-6 sm:px-14 md:px-18 lg:px-28 max-w-360 mx-auto w-full py-10 space-y-12 reveal-content pb-32" style="animation-delay: 400ms;">
    
    <!-- Demonstrated At -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Demonstrated At
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center md:items-start gap-6">
        <div class="flex-shrink-0 bg-white w-24 h-24 rounded-xl shadow-md border border-accent/20 overflow-hidden flex items-center justify-center p-0">
          <img src="/IIT_Bombay.png" alt="Logo" class="w-full h-full object-cover" onerror="this.src='/placeholder.jpeg'; this.onerror=null;" />
        </div>
        <div class="text-center md:text-left pt-2">
          <p class="text-maintext font-heading text-xl md:text-2xl font-bold text-accent">
            Biomedical Engineering and Technology Innovation Centre (BETIC)
          </p>
          <p class="text-maintext font-body text-base md:text-lg mt-2">
            IIT Bombay, India
          </p>
          <p class="text-subtext font-body text-base md:text-lg mt-2 font-semibold">
            Electronics Engineering Intern <span class="text-yellow-500">(Full-Time, On-Site)</span>
          </p>
          <p class="text-gray font-body text-base md:text-lg mt-1">
            <span class="font-semibold text-maintext">Project:</span> Helios 500 Intraoral Scanner Evaluation<br/>
            <span class="font-semibold text-maintext">Guides:</span> Prof. Parag Bhargava and Dr. Bhanupratap Gaur
          </p>
          <p class="text-subtext font-body text-base md:text-lg mt-2 font-semibold">
            19 May to 11 July 2025
          </p>
        </div>
      </div>
    </div>

    <!-- Project Summary -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Project Summary
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          This project involved a comprehensive technical evaluation of the Helios 500 commercial dental intraoral scanner to establish baseline specifications for the research and development of an indigenous intraoral scanning system at BETIC, IIT Bombay.
        </p>
      </div>
    </div>

    <!-- Why this Project is Important -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Why this Project is Important
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Digital intraoral scanning replaces physical dental impressions to enable faster, more accurate CAD/CAM workflows for dental restorations, orthodontic planning, and implantology. Technical benchmarking of commercial systems provides necessary baseline performance criteria for indigenous medical device design.
        </p>
      </div>
    </div>

    <!-- Engineering Context -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Engineering Context
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-4">
        <p class="text-gray font-body text-base md:text-lg leading-relaxed">
          Prior to obtaining the predicate device, the research team worked on developing a custom camera and structured light projection setup for image stitching and 3D reconstruction. The Helios 500 was acquired as a reference standard to identify hardware limitations and clarify system requirements.
        </p>
      </div>
    </div>

    <!-- Project Details -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Project Details
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 space-y-12">
        
        <!-- Module 1 -->
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">1. Device Familiarisation &amp; Workflow Analysis</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Evaluated the complete operational sequence of the Helios 500, including system initialization, optical calibration, real-time geometric mesh visualization, scanning workflow, and export options.
          </p>
          <div class="flex justify-center mt-4 w-full">
            <video controls autoplay loop muted playsinline class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/50">
              <source src="/Projects/DentalIntraoralScanner/scanning.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>

        <hr class="border-accent/10" />

        <!-- Module 2 -->
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">2. Comparative Dental Scanning &amp; 3D Reconstruction</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Tested the scanning system across different dental cast models to evaluate acquisition continuity, surface completeness, and geometric accuracy. Conducted a dual-cast simultaneous scan to evaluate the registration pipeline's capability to maintain separation and detail.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
            <div class="space-y-2">
              <img src="/Projects/DentalIntraoralScanner/lower teeth full scan.jpg" alt="Lower Teeth Full Scan" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
              <p class="text-xs text-subtext text-center italic">Reconstructed 3D geometry of lower dental cast model</p>
            </div>
            <div class="space-y-2">
              <img src="/Projects/DentalIntraoralScanner/two different dentures in one scan.jpg" alt="Two Dentures In One Scan" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
              <p class="text-xs text-subtext text-center italic">Registration of two independent dental cast models scanned simultaneously</p>
            </div>
          </div>
        </div>

        <hr class="border-accent/10" />

        <!-- Module 3 -->
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">3. Non-Dental Object Evaluation</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Tested the scanner on a keyring to evaluate tracking behavior on arbitrary geometries. The scanner struggled to produce a complete reconstruction, showing the dependence of commercial reconstruction algorithms on dental-specific anatomical markers.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
            <div class="space-y-2">
              <img src="/Projects/DentalIntraoralScanner/keyring.jpg" alt="Physical Keyring" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
              <p class="text-xs text-subtext text-center italic">Physical keyring used for non-dental geometry testing</p>
            </div>
            <div class="space-y-2">
              <img src="/Projects/DentalIntraoralScanner/keyringscan.jpg" alt="Keyring 3D Reconstruction Attempt" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
              <p class="text-xs text-subtext text-center italic">Resulting reconstruction scan showing registration errors on flat areas</p>
            </div>
          </div>
        </div>

        <hr class="border-accent/10" />

        <!-- Module 4 -->
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">4. Software &amp; Post-Processing Evaluation</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Analyzed software post-processing tools, including automated mesh trimming, removal of unwanted data points, AI-assisted gap filling for missing regions, and final export formats.
          </p>
          <div class="flex justify-center mt-4 w-full">
            <video controls autoplay loop muted playsinline class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/50">
              <source src="/Projects/DentalIntraoralScanner/scanned.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>

        <hr class="border-accent/10" />

        <!-- Module 5 -->
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">5. Performance Observation &amp; Failure Analysis</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Identified operational limitations, such as temporary software freezes during acquisition. Documented failures of the tracking pipeline to resume scanning seamlessly from the point of interruption, which led to spatial overlaps and registration discrepancies.
          </p>
          <div class="space-y-2 max-w-xl mx-auto mt-4">
            <img src="/Projects/DentalIntraoralScanner/overlapping flaws.jpg" alt="Overlapping Flaws" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20" />
            <p class="text-xs text-subtext text-center italic">Geometric overlap and tracking errors visible in the final mesh</p>
          </div>
        </div>

        <hr class="border-accent/10" />

        <!-- Module 6 -->
        <div class="space-y-4">
          <h3 class="text-xl font-heading font-bold text-maintext text-accent">6. Technical Documentation &amp; Presentation</h3>
          <p class="text-gray font-body text-base md:text-lg leading-relaxed">
            Documented experimental workflows, software feature analysis, and operational findings. Presented the benchmarks and performance limitations to the development team to guide design improvements.
          </p>
        </div>

      </div>
    </div>

    <!-- Tech Stack -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Tech Stack
      </h2>
      <div class="flex flex-wrap gap-4 pt-2">
        {[
          { name: "Intraoral Optical Scanning", icon: "mdi:camera" },
          { name: "3D Surface Reconstruction", icon: "mdi:rotate-3d-variant" },
          { name: "Predicate Device Benchmarking", icon: "mdi:chart-bar" },
          { name: "Comparative Performance Analysis", icon: "mdi:scale-balance" },
          { name: "CAD Model Generation", icon: "mdi:cube-outline" },
          { name: "Image Registration", icon: "mdi:vector-combine" },
          { name: "AI-assisted Post-processing", icon: "mdi:robot" },
          { name: "Functional & Failure-mode Testing", icon: "mdi:alert-circle-outline" },
          { name: "Technical Reporting", icon: "mdi:file-document-outline" }
        ].map((t) => (
          <div class="flex items-center gap-2 rounded-lg px-4 py-2 bg-background border border-accent/20 text-accent font-medium text-sm md:text-base hover:border-accent/60 hover:bg-accent/5 transition-all shadow-sm">
            <Icon name={t.icon} class="w-5 h-5" />
            {t.name}
          </div>
        ))}
      </div>
    </div>

    <!-- Recognition (LOR) -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Recognition
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 flex justify-center">
        <div class="mt-4 flex flex-col items-center justify-center w-full">
          <p class="text-gray font-body text-base md:text-lg leading-relaxed text-center mb-6">
            Letter of Recommendation received from Dr. Bhanupratap Gaur.
          </p>
          <img 
            src="/Projects/DentalIntraoralScanner/Dr. Bhanupratap Gaur - Letter of Recommendation.jpg" alt="Letter of Recommendation by Dr. Bhanupratap Gaur" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20"
          />
        </div>
      </div>
    </div>

    <!-- Certificate -->
    <div class="space-y-4">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext flex items-center gap-3">
        <span class="text-accent">/</span> Certificate
      </h2>
      <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-8 flex justify-center">
        <div class="mt-4 flex justify-center w-full">
          <img 
            src="/Projects/Automaticbloodsmeardevice/Internship Certificate.jpg" alt="Internship Certificate" class="rounded-lg border border-accent/20 shadow-md w-full max-h-64 object-contain bg-black/20"
          />
        </div>
      </div>
    </div>

  </section>
</Layout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }
  @keyframes floating-balloon {
    0% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(3px, -8px) rotate(1deg); }
    66% { transform: translate(-3px, -4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }
</style>

