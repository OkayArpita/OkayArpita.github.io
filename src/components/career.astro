---
// Import your data and the new component at the top of the file
import careerData from '../data/career.json';
import CareerCard from './career-card.astro';
---

<section id="career" class="section-container max-w-6xl mx-auto overflow-hidden">
  <div class="container mx-auto reveal-content" style="animation-delay: 1000ms;">
    <div>
      <h2 class="text-4xl md:text-5xl font-heading font-bold text-maintext mb-4 flex items-center gap-4">
        <span class="text-accent">/</span> Career
      </h2>
      <p class="text-subtext font-body text-base max-w-md pb-10">
        A brief overview of my career
      </p>
    </div>

    <div class="relative">
      {/* Vertical Line*/}
      <div class="absolute left-2.5 md:left-1/2 md:-translate-x-1/2 top-5 bottom-0 w-1 bg-linear-to-b from-accent via-white/10 to-transparent"></div>

      {/* Mobile View */}
      <div class="md:hidden space-y-10">
        {careerData.map((item, index) => (
          <div class="scroll-stat relative pl-8">
            {/* Dot for mobile view*/}
            <div class="absolute left-0 top-1.5 z-10">
              <div class={`w-6 h-6 rounded-full border-[5px] border-[#0a0a0a] 
                          ${index === 0 ? 'bg-accent shadow-[0_0_15px_var(--color-accent)] animate-pulse' : 'bg-accent/50'}`}>
              </div>
            </div>
            
            <CareerCard item={item} variant="mobile" />
          </div>
        ))}
      </div>

      {/* Desktop View */}
      <div class="hidden md:block space-y-8">
        {careerData.map((item, index) => (
          <div id={`career-${index}`} class="scroll-stat relative grid grid-cols-2">
            {/* Center Dot */}
            <div class="absolute left-1/2 -translate-x-1/2 top-2 z-10">
              <div class={`w-6 h-6 rounded-full border-[5px] border-[#0a0a0a] 
                          ${index === 0 ? 'bg-accent shadow-[0_0_15px_var(--color-accent)] animate-pulse' : 'bg-accent/50'}`}>
              </div>
            </div>

            {/* Left Side (even items) */}
            <div class="md:px-8 md:py-0">
              {index % 2 === 0 ? (
                <CareerCard item={item} variant="desktop-left" />
              ) : <div class="h-full pointer-events-none"></div>}
            </div>

            {/* Right Side (odd items) */}
            <div class="md:px-8 md:py-0">
              {index % 2 !== 0 ? (
                <CareerCard item={item} variant="desktop-right" />
              ) : <div class="h-full pointer-events-none"></div>}
            </div>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Career Cursor Badge -->
    <div id="career-cursor-badge" class="career-cursor-badge">
      <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
        <path d="M8 5v14l11-7z" />
      </svg>
      <span>Open</span>
    </div>

  </div>
</section>

<style>
  /* Reveal whole section when website loads */
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Initial state of the card */
  .scroll-stat {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Revealed state while scrolling*/
  .scroll-stat.reveal {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* Career Cursor Badge */
  .career-cursor-badge {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    background-color: #ffffff;
    color: #000000;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
    will-change: transform, opacity;
  }
</style>

<script>
  function revealCards() {
    const cards = document.querySelectorAll('.scroll-stat');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Add a slight delay based on the card's position to create a wave effect
          const index = Array.from(cards).indexOf(entry.target);
          setTimeout(() => {
            entry.target.classList.add('reveal');
          }, (index % 3) * 150); // Delay resets every row for a clean staggered look
          
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15, // Trigger when 15% of the card is visible
      rootMargin: '0px 0px -10px 0px' // Trigger slightly before it hits the viewport
    });

    cards.forEach(card => observer.observe(card));
  }

  // Runs on initial load
  revealCards();
  
  const initCareerCursor = () => {
    const badge = document.getElementById('career-cursor-badge');
    const tiles = document.querySelectorAll('.career-tile');
    if (!badge || tiles.length === 0) return;

    let mouseX = 0, mouseY = 0;
    let badgeX = 0, badgeY = 0;
    let currentScale = 0.5, targetScale = 0.5;
    let currentOpacity = 0, targetOpacity = 0;

    const onMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    };
    window.addEventListener('mousemove', onMouseMove);

    tiles.forEach(tile => {
      tile.addEventListener('mouseenter', () => { targetScale = 1; targetOpacity = 1; });
      tile.addEventListener('mouseleave', () => { targetScale = 0.5; targetOpacity = 0; });
    });

    let animationFrameId: number;
    const animate = () => {
      badgeX += (mouseX - badgeX) * 0.15;
      badgeY += (mouseY - badgeY) * 0.15;
      currentScale += (targetScale - currentScale) * 0.15;
      currentOpacity += (targetOpacity - currentOpacity) * 0.15;

      badge.style.opacity = currentOpacity.toFixed(3);
      badge.style.transform = `translate3d(${badgeX}px, ${badgeY}px, 0) translate(-50%, -50%) scale(${currentScale.toFixed(3)})`;

      animationFrameId = requestAnimationFrame(animate);
    };
    animate();

    return () => {
      window.removeEventListener('mousemove', onMouseMove);
      cancelAnimationFrame(animationFrameId);
    };
  };

  let cleanupCareerCursor: (() => void) | null = null;

  const setupCareerSection = () => {
    revealCards();
    if (cleanupCareerCursor) cleanupCareerCursor();
    cleanupCareerCursor = initCareerCursor();
  };

  document.addEventListener('astro:after-swap', setupCareerSection);
  window.addEventListener('load', setupCareerSection);
  // Also run immediately since astro might not trigger load on client-side nav
  setupCareerSection();
</script>
