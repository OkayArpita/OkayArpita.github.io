---
interface Props {
  item: {
    period: string;
    role: string;
    company: string;
    description: string;
    skills: string[];
    logo?: string;
  };
  variant: 'mobile' | 'desktop-left' | 'desktop-right';
}

const { item, variant } = Astro.props;

const isMobile = variant === 'mobile';
const isLeft = variant === 'desktop-left';

const alignmentClass = isLeft ? "text-right" : "";
const skillContainerClasses = `flex flex-wrap gap-3 ${isLeft ? 'justify-end' : ''}`;
---

<div class={`bg-accent/5 border border-accent/10 p-8 md:p-10 rounded-2xl hover:border-accent/40 transition-all group ${alignmentClass}`}>
  
  <div class={`flex gap-6 items-start mb-6 ${isLeft ? 'flex-row-reverse' : ''}`}>
    {item.logo && (
      <img 
        src={`/${item.logo}`} 
        alt={`${item.company} logo`} 
        class="w-24 h-24 md:w-28 md:h-28 object-contain rounded-xl bg-white/5 p-2 border border-accent/20 flex-shrink-0" 
      />
    )}
    
    <div class="flex-1 mt-1">
      <span class={`font-mono text-base md:text-lg tracking-widest uppercase text-accent/75`}>{item.period}</span>
      <h3 class="text-3xl md:text-4xl font-heading font-bold text-maintext mt-2 mb-2">{item.role}</h3>
      <p class="text-accent text-lg md:text-xl font-semibold">{item.company}</p>
    </div>
  </div>

  <p class="text-subtext font-body text-lg md:text-xl leading-relaxed mb-8">{item.description}</p>
  
  <div class={skillContainerClasses}>
    {item.skills.map((skill: string) => (
      <span class={`rounded-lg text-sm md:text-base px-4 md:px-6 py-2 bg-accent/5 border border-accent/10 text-accent/80 group-hover:border-accent/40 group-hover:text-accent`}>{skill}</span>
    ))}
  </div>
</div>
