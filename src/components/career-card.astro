---
interface Props {
  item: {
    period: string;
    role: string;
    company: string;
    description: string;
    skills: string[];
    logo?: string;
    link?: string;
  };
  variant: 'mobile' | 'desktop-left' | 'desktop-right';
}

const { item, variant } = Astro.props;

const isMobile = variant === 'mobile';
const isLeft = variant === 'desktop-left';

const alignmentClass = isLeft ? "text-right" : "";
const skillContainerClasses = `flex flex-wrap gap-2.5 ${isLeft ? 'justify-end' : ''}`;
---

<a href={item.link} class={`block cursor-pointer bg-accent/5 border border-accent/10 p-6 md:p-8 rounded-2xl hover:border-accent/40 hover:bg-accent/10 transition-all group ${alignmentClass}`}>
  
  <div class={`flex gap-5 items-start mb-5 ${isLeft ? 'flex-row-reverse' : ''}`}>
    {item.logo && (
      <img 
        src={`/${item.logo}`} 
        alt={`${item.company} logo`} 
        class="w-20 h-20 md:w-24 md:h-24 object-contain rounded-md bg-white/5 p-1.5 border border-accent/20 flex-shrink-0" 
      />
    )}
    
    <div class="flex-1 mt-1">
      <span class={`font-mono text-sm tracking-widest uppercase text-accent/75`}>{item.period}</span>
      <h3 class="text-2xl md:text-3xl font-heading font-bold text-maintext mt-2 mb-1">{item.role}</h3>
      <p class="text-accent text-base md:text-lg font-semibold">{item.company}</p>
    </div>
  </div>

  <p class="text-subtext font-body text-base md:text-lg leading-relaxed mb-6">{item.description}</p>
  
  <div class={skillContainerClasses}>
    {item.skills.map((skill: string) => (
      <span class={`rounded-md text-xs md:text-sm px-3 md:px-5 py-1.5 bg-accent/5 border border-accent/10 text-accent/80 group-hover:border-accent/40 group-hover:text-accent`}>{skill}</span>
    ))}
  </div>
</a>
