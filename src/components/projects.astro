---
import ProjectCard from './project-card.astro';
import projectsData from '../data/projects.json';
---

<section id="projects" class="section-container overflow-hidden">
  <div class="container mx-auto">
    <div class="mb-16 project-header">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
          <span class="text-accent">/</span> Featured Projects
        </h2>
      <p class="text-subtext font-body text-sm max-w-md">
        A selection of professional work, published apps, and experimental prototypes.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projectsData.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </div>

  <!-- Project Cursor Badge -->
  <div id="project-cursor-badge" class="project-cursor-badge">
    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
      <path d="M8 5v14l11-7z" />
    </svg>
    <span>Open</span>
  </div>
</section>


<style>
  /* Project Cursor Badge */
  .project-cursor-badge {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    background-color: #ffffff;
    color: #000000;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
    will-change: transform, opacity;
  }

  /* Header Initial State */
  .project-header {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Cards Initial State */
  .project-card {
    opacity: 0; /* Ensuring cards start hidden too */
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Shared Revealed State */
  .project-header.reveal,
  .project-card.reveal {
    opacity: 1 !important;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  const initProjectReveal = () => {
    const header = document.querySelector('.project-header');
    const cards = document.querySelectorAll('.project-card');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const target = entry.target as HTMLElement;
          
          // Check if the intersecting element is the header
          if (target.classList.contains('project-header')) {
            target.classList.add('reveal');
            observer.unobserve(target);
          } 
          // Check if the intersecting element is a project card
          else if (target.classList.contains('project-card')) {
            const index = Array.from(cards).indexOf(target);
            
            // Stagger effect based on row position (only for cards)
            setTimeout(() => {
              target.classList.add('reveal');
            }, (index % 3) * 150);
            
            observer.unobserve(target);
          }
        }
      });
    }, { 
      threshold: 0.15, 
      rootMargin: '0px 0px -10px 0px' 
    });

    // Observe the header
    if (header) observer.observe(header);
    
    // Observe all cards
    cards.forEach(card => observer.observe(card));
  };

  const initCursorBadge = () => {
    const badge = document.getElementById('project-cursor-badge');
    const cards = document.querySelectorAll('.project-card');
    if (!badge || cards.length === 0) return;

    let mouseX = 0;
    let mouseY = 0;
    let badgeX = 0;
    let badgeY = 0;
    let currentScale = 0.5;
    let targetScale = 0.5;
    let currentOpacity = 0;
    let targetOpacity = 0;
    let isHovering = false;

    // Track mouse coordinates globally
    const onMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    };

    window.addEventListener('mousemove', onMouseMove);

    // Mouse entering and leaving cards
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        isHovering = true;
        targetScale = 1;
        targetOpacity = 1;
      });

      card.addEventListener('mouseleave', () => {
        isHovering = false;
        targetScale = 0.5;
        targetOpacity = 0;
      });
    });

    let animationFrameId: number;

    const animate = () => {
      // Smoothen coordinates with a LERP factor (0.15)
      badgeX = mouseX;
      badgeY = mouseY;

      // Smoothen scale and opacity
      currentScale += (targetScale - currentScale) * 0.15;
      currentOpacity += (targetOpacity - currentOpacity) * 0.15;

      badge.style.opacity = currentOpacity.toFixed(3);
      badge.style.transform = `translate3d(${badgeX}px, ${badgeY}px, 0) translate(-50%, -50%) scale(${currentScale.toFixed(3)})`;

      animationFrameId = requestAnimationFrame(animate);
    };

    animate();

    // Return cleanup function to run on navigation/unmount
    return () => {
      window.removeEventListener('mousemove', onMouseMove);
      cancelAnimationFrame(animationFrameId);
    };
  };

  let cleanupCursor: (() => void) | null = null;

  const setupAll = () => {
    if (cleanupCursor) {
      cleanupCursor();
    }
    initProjectReveal();
    cleanupCursor = initCursorBadge();
  };

  window.addEventListener('load', setupAll);
  document.addEventListener('astro:after-swap', setupAll);
</script>
