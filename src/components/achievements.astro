---
import { Icon } from 'astro-icon/components';
import achievementsData from '../data/achievements.json';
---

<section id="achievements" class="section-container">
  <div class="container mx-auto max-w-4xl">
    
    <div class="mb-12">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
        <span class="text-accent">/</span> Achievements
      </h2>
      <p class="text-subtext font-body text-sm max-w-md">
        Hackathons, competitions, and awards in the robotics and hardware space.
      </p>
    </div>

    <div class="space-y-6">
      {achievementsData.map((item, index) => (
        <a href={item.link} id={`achievement-${index}`} class="achievement-card opacity-0 group flex flex-col sm:flex-row items-start gap-6 bg-accent/5 border border-white/5 border-l-4 border-l-accent p-6 rounded-r-2xl hover:bg-accent/10 transition-all duration-300 block">
          
          <!-- Logo or Trophy Icon -->
          <div class="shrink-0 mt-1">
            {item.logo ? (
              <img 
                src={`/${item.logo}`} 
                alt={`${item.event} logo`} 
                class="w-16 h-16 object-contain rounded-md bg-white/5 p-1 border border-accent/20" 
              />
            ) : (
              <div class="w-16 h-16 flex items-center justify-center rounded-md bg-accent/10 border border-accent/20 text-accent">
                <Icon name="mdi:trophy-outline" class="w-8 h-8" />
              </div>
            )}
          </div>

          <!-- Content -->
          <div class="flex-1 w-full">
            <h3 class="text-xl font-heading font-bold text-maintext mb-5">{item.event}</h3>
            
            <div class="space-y-5">
              {item.editions.map((edition) => (
                <div class="relative pl-4 border-l-2 border-white/10 hover:border-accent/50 transition-colors">
                  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-2 mb-2">
                    <div>
                      {edition.event && <h4 class="text-maintext text-[15px] font-bold mb-0.5">{edition.event}</h4>}
                      <h5 class="text-accent text-sm font-semibold">{edition.award}</h5>
                    </div>
                    <span class="font-mono text-[11px] tracking-widest uppercase text-accent/75 bg-accent/10 px-3 py-1 rounded-full whitespace-nowrap mt-1 sm:mt-0">
                      {edition.year}
                    </span>
                  </div>
                  <p class="text-subtext font-body text-sm leading-relaxed">
                    {edition.description}
                  </p>
                </div>
              ))}
            </div>

          </div>

        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .achievement-card {
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .achievement-card.reveal {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  const revealAchievements = () => {
    const cards = document.querySelectorAll('.achievement-card');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const target = entry.target;
          const index = Array.from(cards).indexOf(target);
          
          setTimeout(() => {
            target.classList.add('reveal');
          }, index * 150);
          
          observer.unobserve(target);
        }
      });
    }, { 
      threshold: 0.15,
      rootMargin: '0px 0px -50px 0px'
    });

    cards.forEach(card => observer.observe(card));
  }
  
  window.addEventListener('load', revealAchievements);
  document.addEventListener('astro:after-swap', revealAchievements);
</script>
